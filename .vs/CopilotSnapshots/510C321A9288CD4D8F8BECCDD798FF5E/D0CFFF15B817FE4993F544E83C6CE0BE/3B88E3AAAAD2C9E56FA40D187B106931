<Window x:Class="PointofSale.Views.DepartmentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Departments"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Departments" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Manage department list (Admin only)"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         Margin="12,0,12,0"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource HintTextBox}"
                         Tag="Search departments..."
                         TextChanged="SearchBox_TextChanged"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ModernButton}" Content="Add" Margin="0,0,8,0" Click="Add_Click"/>
                    <Button Style="{StaticResource ModernButton}" Content="Edit" Margin="0,0,8,0" Click="Edit_Click"/>
                    <Button Style="{StaticResource ModernButton}" Content="Delete" Click="Delete_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">

            <DataGrid x:Name="Grid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          GridLinesVisibility="None"
          Background="{StaticResource BgBrush}"
          Foreground="White"
          RowBackground="{StaticResource BgBrush}"
          AlternatingRowBackground="{StaticResource PanelBrush}"
          BorderThickness="0"
          SelectionMode="Single"
          MouseDoubleClick="Grid_MouseDoubleClick">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Department" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120"/>
                    <DataGridTextColumn Header="Tax Code" Binding="{Binding TaxCode}" Width="120"/>
                    <DataGridTextColumn Header="Margin %" Binding="{Binding MarginPercent}" Width="120"/>
                    <DataGridTextColumn Header="Markup %" Binding="{Binding MarkupPercent}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
