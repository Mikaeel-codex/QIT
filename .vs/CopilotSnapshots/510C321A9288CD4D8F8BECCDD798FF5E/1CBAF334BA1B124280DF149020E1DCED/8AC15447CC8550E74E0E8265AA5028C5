<Window x:Class="PointofSale.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Inventory Item"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#000000"
        Foreground="White">

    <Window.Resources>

        <!-- Compact TextBox style (QuickBooks-like) -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#111" />
            <Setter Property="BorderBrush" Value="#2E2E2E" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- DARK COMBOBOX STYLE (FIXED: CLICKABLE + WORKS WITH IsEditable) -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="4,2"/>

            <!-- Dropdown popup styling -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#111"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">

                            <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <!-- Shows selected item when NOT editable -->
                                <ContentPresenter x:Name="ContentSite"
                                              Grid.Column="0"
                                              Margin="6,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                <!-- Required for IsEditable=True -->
                                <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="6,0,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     VerticalContentAlignment="Center"
                                     Visibility="Hidden"
                                     Focusable="True"/>

                                <!-- Clickable dropdown button -->
                                <ToggleButton x:Name="ToggleButton"
                                          Grid.Column="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Path VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Fill="White"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                </ToggleButton>
                            </Grid>

                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False">
                                <Border Background="#111"
                                    BorderBrush="#2E2E2E"
                                    BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Editable mode -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact buttons -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="10,2"/>
        </Style>

        <!-- Multi-line textboxes -->
        <Style x:Key="MultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="90" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

    </Window.Resources>


    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top title bar -->
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,6">
            <TextBlock Text="Add Inventory Item"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Inventory Item Info (top strip) -->
            <Border Grid.Row="0"
                    Background="#111"
                    CornerRadius="3"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    Padding="8"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Picture box -->
                    <Border Width="90" Height="62"
                            Background="#F4F4F4"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="No picture"
                                       Foreground="#777"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Click here to assign"
                                       Foreground="#999"
                                       FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Item Name -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Item Name"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="NameBox" />
                            <TextBlock Grid.Column="1"
                                       Text="*"
                                       Foreground="Red"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main form area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- BASIC INFO -->
                <Border Grid.Column="0"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="8,0">
                                <TextBlock Text="Basic Info"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="▾" Foreground="#AAA" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- Content -->
                        <Grid Grid.Row="1" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                            </Grid.ColumnDefinitions>

                            <!-- Department -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Department" VerticalAlignment="Center" Foreground="White" FontSize="12"/>
                            <ComboBox x:Name="DepartmentBox"
                                      Grid.Row="0" Grid.Column="1"
                                      IsEditable="True"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="*" Foreground="Red" FontSize="13" VerticalAlignment="Center"/>

                            <!-- Item Description -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Item Description" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="DescriptionBox"
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,6,0,6"
                                     Style="{StaticResource MultilineTextBox}"/>

                            <!-- Size -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="SizeBox"
                                     Grid.Row="2" Grid.Column="1"
                                     Margin="0,6,0,0"/>

                            <!-- Reg Price -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Reg Price" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="PriceBox"
                                     Grid.Row="3" Grid.Column="1"
                                     Margin="0,6,0,0"/>

                            <!-- Avg. Unit Cost -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Avg. Unit Cost" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="AvgUnitCostBox"
                                     Grid.Row="4" Grid.Column="1"
                                     Margin="0,6,0,0"/>

                            <!-- On-Hand Qty -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="On-Hand Qty" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="StockBox"
                                     Grid.Row="5" Grid.Column="1"
                                     Margin="0,6,0,0"/>

                            <!-- Tax -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Tax" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <ComboBox x:Name="TaxBox"
                                      Grid.Row="6" Grid.Column="1"
                                      Margin="0,6,0,0">
                                <ComboBoxItem Content="Tax"/>
                                <ComboBoxItem Content="No Tax"/>
                            </ComboBox>

                            <!-- SKU (replacing UPC) -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="SKU" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="SkuBox"
                                     Grid.Row="7" Grid.Column="1"
                                     Margin="0,6,0,0"
                                     PreviewTextInput="SkuBox_PreviewTextInput"
                                     DataObject.Pasting="SkuBox_Pasting"
                                     TextChanged="SkuBox_TextChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- MORE INFO -->
                <Border Grid.Column="1"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,4,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="8,0">
                                <TextBlock Text="More Info"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="▾" Foreground="#AAA" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="105"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="105"/>
                            </Grid.ColumnDefinitions>

                            <!-- Vendor + Add Supplier -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Supplier" VerticalAlignment="Center" Foreground="White" FontSize="12"/>
                            <ComboBox x:Name="VendorBox"
                                      Grid.Row="0" Grid.Column="1"
                                      IsEditable="True" Grid.ColumnSpan="2" Margin="0,0,60,0"/>
                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    Width="55"
                                    MinWidth="0"
                                    Height="22"
                                    Padding="6,1"
                                    HorizontalAlignment="Right"
                                    Margin="6,0,0,0"
                                    Click="AddSupplier_Click">

                                <TextBlock Text="Add. Rep"
                                           FontSize="10"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </Button>


                            <!-- Order Cost -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Order Cost" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="OrderCostBox"
                                     Grid.Row="1" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,6,0,0"/>

                            <!-- Reorder Point -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Reorder Point" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="ReorderPointBox"
                                     Grid.Row="2" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,6,0,0"/>

                            <!-- Item No -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Item No." VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="ItemNoBox"
                                     Grid.Row="3" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,6,0,0"
                                     IsReadOnly="True"/>

                            <!-- ALU -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ALU" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="AluBox"
                                     Grid.Row="4" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,6,0,0"
                                     TextChanged="AluBox_TextChanged"/>

                            <!-- Unit of Measure -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Unit of Measure" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <ComboBox x:Name="UomBox"
                                      Grid.Row="5" Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,6,0,0">
                                <ComboBoxItem Content="Each"/>
                                <ComboBoxItem Content="Box"/>
                                <ComboBoxItem Content="Carton"/>
                            </ComboBox>

                            <!-- Manufacturer -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Manufacturer" VerticalAlignment="Center" Margin="0,6,0,0" Foreground="White" FontSize="12"/>
                            <TextBox x:Name="ManufacturerBox"
                                     Grid.Row="6" Grid.Column="1"
                                     Grid.ColumnSpan="2"
                                     Margin="0,6,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- COMMENTS (unchanged) -->
                <Border Grid.Column="2"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="8" Margin="23,0,0,226">

                    <Grid Margin="1,0,1,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="8,0">
                                <TextBlock Text="Comments"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="White"/>
                                <TextBlock Text="▾"
                                           Foreground="#AAA"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <TextBox x:Name="CommentsBox"
                                 Grid.Row="1"
                                 Margin="6,0,10,16"
                                 Background="#F3F0D7"
                                 Foreground="Black"
                                 BorderBrush="#C8C8A8"
                                 FontSize="12"
                                 Padding="6"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom buttons -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Save &amp; New"
                    Width="120"
                    Height="30"
                    HorizontalAlignment="Left"
                    Click="SaveAndNew_Click"/>

            <Button Grid.Column="1"
                    Content="Save"
                    Width="110"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>

            <Button Grid.Column="2"
                    Content="Cancel"
                    Width="110"
                    Height="30"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
