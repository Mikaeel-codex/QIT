<Window x:Class="PointofSale.Views.PointOfSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Point of Sale"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Foreground="White">

    <Window.Resources>
        <!-- Dark theme brushes -->
        <SolidColorBrush x:Key="BgBrush" Color="#000000"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#111111"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2B2B2B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#BBBBBB"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F66C8"/>
        <SolidColorBrush x:Key="RowAltBrush" Color="#0F0F0F"/>
        <SolidColorBrush x:Key="RowBrush" Color="#181818"/>

        <!-- Simple modern button style used locally to ensure consistent look -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#1F4E9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- DataGrid header style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#222831"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
        </Style>

        <!-- DataGrid row style for dark zebra -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource RowBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource RowAltBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#274A8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="8"
          PreviewKeyDown="Grid_PreviewKeyDown"
          Loaded="MainWindow_Loaded">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP NAVBAR -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sales Receipt"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="6,0,14,0"
                               Foreground="White"/>

                    <Button Content="I Want to..."
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,8,0"/>

                    <TextBox x:Name="ScanBoxTop"
                             Width="420"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             Background="#0E0E0E"
                             BorderBrush="{StaticResource BorderBrush}"
                             Foreground="White"
                             FontSize="13"
                             Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="ScanBox_KeyDown"
                             ToolTip="Scan or enter item information"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox x:Name="CustomerBoxTop"
                             Width="300"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             Background="#0E0E0E"
                             BorderBrush="{StaticResource BorderBrush}"
                             Foreground="White"
                             FontSize="13"
                             Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="CustomerBox_KeyDown"
                             ToolTip="Enter customer name or phone"/>

                    <TextBlock x:Name="UserLabelTop"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,12,0"/>

                    <Button Style="{StaticResource ModernButton}"
                            Content="Logout"
                            Click="LogoutBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN POS LAYOUT (Sales Receipt style) -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SEARCH / CONTROLS ROW -->
            <Border Grid.Row="0"
                    Background="#070707"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="430"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="I Want to..."
                            Background="#2F66C8"
                            Foreground="White"
                            BorderBrush="#1F4E9A"
                            BorderThickness="1"
                            Height="28"
                            Padding="10,0"
                            Cursor="Hand"/>

                    <TextBox Grid.Column="1"
                             x:Name="ScanBox"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Background="#0E0E0E"
                             Foreground="White"
                             FontSize="13"
                             Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="ScanBox_KeyDown"
                             ToolTip="Scan or enter item information"/>

                    <TextBox Grid.Column="3"
                             x:Name="CustomerBox"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Background="#0E0E0E"
                             Foreground="White"
                             FontSize="13"
                             Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="CustomerBox_KeyDown"
                             ToolTip="Enter customer name or phone"/>
                </Grid>
            </Border>

            <!-- RECEIPT GRID -->
            <Border Grid.Row="1"
                    Background="#070707"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DataGrid x:Name="ReceiptGrid"
                          ItemsSource="{Binding Cart}"
                          AlternationCount="2"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowDetailsVisibilityMode="VisibleWhenSelected"
                          FontSize="13"
                          Background="Transparent"
                          RowBackground="{StaticResource RowBrush}"
                          AlternatingRowBackground="{StaticResource RowAltBrush}"
                          Foreground="White">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item #"
                                            Binding="{Binding SKU}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Item Name"
                                            Binding="{Binding Name}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Attribute"
                                            Binding="{Binding Attribute}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Qty"
                                            Binding="{Binding Qty}"
                                            Width="60"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding UnitPrice, StringFormat=N2}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Ext Price"
                                            Binding="{Binding LineTotal, StringFormat=N2}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Tax Code"
                                            Binding="{Binding TaxCode}"
                                            Width="90"/>
                    </DataGrid.Columns>

                    <!-- Row action strip -->
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#183B72"
                                    Padding="8"
                                    BorderBrush="#142C57"
                                    BorderThickness="0,1,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="Edit"
                                            Height="24" MinWidth="70"
                                            Margin="0,0,8,0"
                                            Background="#2F66C8" Foreground="White"
                                            BorderBrush="#1F4E9A" BorderThickness="1"
                                            Click="EditLine_Click"/>

                                    <Button Grid.Column="1"
                                            Content="Return Item"
                                            Height="24" MinWidth="90"
                                            Margin="0,0,8,0"
                                            Background="#2F66C8" Foreground="White"
                                            BorderBrush="#1F4E9A" BorderThickness="1"
                                            Click="ReturnLine_Click"/>

                                    <Button Grid.Column="3"
                                            Content="Qty/Price/Discount"
                                            Height="24" MinWidth="140"
                                            Margin="0,0,8,0"
                                            Background="#2F66C8" Foreground="White"
                                            BorderBrush="#1F4E9A" BorderThickness="1"
                                            Click="QtyPriceDiscount_Click"/>

                                    <Button Grid.Column="4"
                                            Content="Qty+"
                                            Height="24" MinWidth="60"
                                            Margin="0,0,8,0"
                                            Background="#2F66C8" Foreground="White"
                                            BorderBrush="#1F4E9A" BorderThickness="1"
                                            Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Grid.Column="5"
                                            Content="Qty-"
                                            Height="24" MinWidth="60"
                                            Margin="0,0,8,0"
                                            Background="#2F66C8" Foreground="White"
                                            BorderBrush="#1F4E9A" BorderThickness="1"
                                            Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Grid.Column="6"
                                            Content="Remove"
                                            Height="24" MinWidth="80"
                                            Background="#D9534F" Foreground="White"
                                            BorderBrush="#B54541" BorderThickness="1"
                                            Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>

                </DataGrid>
            </Border>

            <!-- PAYMENTS + TOTALS -->
            <Border Grid.Row="2"
                    Background="#0B0B0B"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="420"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Cash" Width="140" Height="46" Margin="0,0,8,0"
                                Style="{StaticResource ModernButton}"
                                Click="Cash_Click"/>
                        <Button Content="Credit" Width="140" Height="46" Margin="0,0,8,0"
                                Style="{StaticResource ModernButton}"
                                Click="Credit_Click"/>
                        <Button Content="Check" Width="140" Height="46" Margin="0,0,8,0"
                                Style="{StaticResource ModernButton}"
                                Click="Check_Click"/>
                        <Button Content="Gift" Width="140" Height="46" Margin="0,0,8,0"
                                Style="{StaticResource ModernButton}"
                                Click="Gift_Click"/>
                        <Button Content="Account" Width="140" Height="46"
                                Style="{StaticResource ModernButton}"
                                Click="Account_Click"/>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="No. of Items Sold" HorizontalAlignment="Right" Foreground="White"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ItemsSold}" HorizontalAlignment="Right" Foreground="White"/>

                        <TextBlock Grid.Row="1" Text="Total Qty Sold" HorizontalAlignment="Right" Foreground="White"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalQtySold}" HorizontalAlignment="Right" Foreground="White"/>

                        <TextBlock Grid.Row="2" Text="SubTotal" HorizontalAlignment="Right" Foreground="White"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Subtotal, StringFormat=N2}" HorizontalAlignment="Right" Foreground="White"/>

                        <TextBlock Grid.Row="3" Text="Tax" HorizontalAlignment="Right" Foreground="White"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Tax, StringFormat=N2}" HorizontalAlignment="Right" Foreground="White"/>

                        <TextBlock Grid.Row="4" Text="Total" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="White"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Total, StringFormat=N2}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,8,0,0" Foreground="White"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>