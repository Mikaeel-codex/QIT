<Window x:Class="PointofSale.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0"
                CornerRadius="16"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,12,0">

            <DockPanel LastChildFill="True">

                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Quick Inventory Till"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Admin Dashboard"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel>
                    <Button Style="{StaticResource GoldButton}" Height="44" Margin="0,0,0,10"
                            Content="Make a Sale" Click="MakeSale_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="Receive Stock" Click="ReceiveStock_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="Item List" Click="Products_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="Customer List" Click="CustomersList_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="Employees / Users" Click="Users_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="Reports" Click="Reports_Click"/>

                    <Button Style="{StaticResource ModernButton}" Height="40" Margin="0,0,0,8"
                            Content="End of Day" Click="EndOfDay_Click"/>

                    <Button x:Name="SettingsBtn" Style="{StaticResource ModernButton}" Height="40"
                            Content="Settings" Click="Settings_Click"/>

                    <Button x:Name="ItemsListBtn" Style="{StaticResource ModernButton}" Height="40"
                            Content="ItemsList" Click="ItemsList_Click"/>
                </StackPanel>

            </DockPanel>
        </Border> 

        <!-- MAIN AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0"
                    CornerRadius="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    

                    <StackPanel>
                        <TextBlock Text="Navigator" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Quick actions to manage your store"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    

                    <TextBox Grid.Column="1"
                             Style="{StaticResource HintTextBox}"
                             Tag="Quick search (customer, item, receipt...)"
                             VerticalContentAlignment="Center"/>

                    <Button Grid.Column="2"
                            x:Name="SignInBtn"
                            Style="{StaticResource GoldButton}"
                            Content="Sign in"
                            Padding="14,8"
                            Margin="12,0,0,0"
                            Click="SignIn_Click"/>

                </Grid>
            </Border>

            <!-- Tiles -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="4" Margin="0,0,0,10">

                    <!-- TILE TEMPLATE: Border + Button -->
                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="MakeSaleBtn"
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="MakeSale_Click">
                            <StackPanel>
                                <TextBlock Text="🧾  Make a Sale" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Open POS screen"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="SalesHistoryBtn" 
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="SalesHistory_Click">
                            <StackPanel>
                                <TextBlock Text="📒  Sales History" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="View receipts &amp; totals"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="ProductsBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="Products_Click">
                            <StackPanel>
                                <TextBlock Text="📦  Inventory" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage products &amp; stock"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                            <Button Style="{StaticResource ModernButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="10"
                                    Click="ItemsList_Click">
                            <StackPanel>
                                <TextBlock Text="🏷  ItemsList" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Stock-in / adjustments"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="ReceiveStockBtn"
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="ReceiveStock_Click">
                            <StackPanel>
                                <TextBlock Text="📥  Receive Stock" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Stock-in / adjustments"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="CustomersListBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="CustomersList_Click">
                            <StackPanel>
                                <TextBlock Text="👥  Customers" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Customer list &amp; details"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="EmployeesBtn" 
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="Users_Click">
                            <StackPanel>
                                <TextBlock Text="🧑‍💼  Employees / Users" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Cashiers, roles, access"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="ReportsBtn"
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="Reports_Click">
                            <StackPanel>
                                <TextBlock Text="📊  Reports" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Performance &amp; analytics"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                        <Button x:Name="EndOfDayBtn"
                                Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="EndOfDay_Click">
                            <StackPanel>
                                <TextBlock Text="🧾  End of Day" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Close out daily totals"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12"
                            CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="14">
                            <Button Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left"
                                Padding="10"
                                Click="Settings_Click"> 
                            <StackPanel>
                                <TextBlock Text=" ⚙️ Settings" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="View receipts &amp; totals"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
