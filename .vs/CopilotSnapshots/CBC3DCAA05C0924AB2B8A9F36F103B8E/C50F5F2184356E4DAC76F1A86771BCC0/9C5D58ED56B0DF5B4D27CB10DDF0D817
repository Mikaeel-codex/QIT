<Window x:Class="PointofSale.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Inventory Item"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#000000"
        Foreground="White">

    <Window.Resources>
        <!-- Improve TextBox readability and prevent clipping -->
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#111" />
            <Setter Property="BorderBrush" Value="#2E2E2E" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Multi-line textboxes should be larger -->
        <Style x:Key="MultilineTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="80" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top title bar -->
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
            <TextBlock Text="Add Inventory Item"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Inventory Item Info (top strip) -->
            <Border Grid.Row="0"
                    Background="#111"
                    CornerRadius="3"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Picture box -->
                    <Border Width="90" Height="70"
                            Background="#F4F4F4"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="No picture"
                                       Foreground="#777"
                                       FontSize="11"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Click here to assign"
                                       Foreground="#999"
                                       FontSize="10"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Item Name -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Item Name"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="NameBox" />
                            <TextBlock Grid.Column="1"
                                       Text="*"
                                       Foreground="Red"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main form area - 4 columns layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- BASIC INFO COLUMN 1 -->
                <Border Grid.Column="0"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="10,0">
                                <TextBlock Text="Basic Info"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontSize="12"/>
                            </DockPanel>
                        </Border>

                        <!-- Content -->
                        <StackPanel Grid.Row="1" Margin="10">
                            <TextBlock Text="Department" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <ComboBox x:Name="DepartmentBox"
                                      Height="28"
                                      IsEditable="True"
                                      BorderBrush="#2E2E2E"
                                      Background="#111"
                                      Foreground="White"
                                      Margin="0,2,0,8"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="12"/>

                            <TextBlock Text="Size" VerticalAlignment="Center" Foreground="White" FontSize="11" Margin="0,8,0,0"/>
                            <TextBox x:Name="SizeBox"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="Reg Price" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="PriceBox"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="Tax" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <ComboBox x:Name="TaxBox"
                                      Height="28"
                                      Margin="0,2,0,0"
                                      BorderBrush="#2E2E2E"
                                      Background="#111"
                                      Foreground="White">
                                <ComboBoxItem Content="Tax"/>
                                <ComboBoxItem Content="No Tax"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BASIC INFO COLUMN 2 -->
                <Border Grid.Column="1"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="10,0">
                                <TextBlock Text="Pricing"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontSize="12"/>
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="10">
                            <TextBlock Text="Avg. Unit Cost" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="AvgUnitCostBox"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="Order Cost" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="OrderCostBox"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="On-Hand Qty" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="StockBox"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="Reorder Point" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="ReorderPointBox"
                                     Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MORE INFO COLUMN 3 -->
                <Border Grid.Column="2"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="10,0">
                                <TextBlock Text="More Info"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontSize="12"/>
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="10">
                            <TextBlock Text="Vendor" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <ComboBox x:Name="VendorBox"
                                      Height="28"
                                      IsEditable="True"
                                      BorderBrush="#2E2E2E"
                                      Background="#111"
                                      Foreground="White"
                                      Margin="0,2,0,8"/>

                            <TextBlock Text="Item No." VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="ItemNoBox"
                                     IsReadOnly="True"
                                     Background="#111"
                                     BorderBrush="#2E2E2E"
                                     Foreground="White"
                                     Margin="0,2,0,8"/>

                            <TextBlock Text="ALU" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="AluBox"
                                     Margin="0,2,0,8"
                                     TextChanged="AluBox_TextChanged"/>

                            <TextBlock Text="UPC" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="UpcBox"
                                     Margin="0,2,0,8"
                                     TextChanged="UpcBox_TextChanged"/>

                            <TextBlock Text="Unit of Measure" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                            <ComboBox x:Name="UomBox"
                                      Height="28"
                                      Margin="0,2,0,0"
                                      BorderBrush="#2E2E2E"
                                      Background="#111"
                                      Foreground="White">
                                <ComboBoxItem Content="Each"/>
                                <ComboBoxItem Content="Box"/>
                                <ComboBoxItem Content="Carton"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DESCRIPTION & COMMENTS COLUMN 4 -->
                <Border Grid.Column="3"
                        Background="#111"
                        CornerRadius="3"
                        BorderBrush="#2E2E2E"
                        BorderThickness="1"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="#111" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
                            <DockPanel Margin="10,0">
                                <TextBlock Text="Details"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontSize="12"/>
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="10" Spacing="8">
                            <TextBlock Text="Description" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="DescriptionBox"
                                     Style="{StaticResource MultilineTextBox}"
                                     BorderBrush="#2E2E2E"
                                     Background="#111"
                                     Foreground="White"
                                     Height="70"/>

                            <TextBlock Text="Manufacturer" Foreground="White" FontSize="11"/>
                            <TextBox x:Name="ManufacturerBox"/>

                            <CheckBox x:Name="SyncToMobileBox"
                                      Content="Sync to Mobile"
                                      Foreground="White"
                                      Margin="0,4,0,0"/>
                        </StackPanel>

                        <TextBox x:Name="CommentsBox"
                                 Grid.Row="2"
                                 Margin="10,0,10,10"
                                 Style="{StaticResource MultilineTextBox}"
                                 Background="#111"
                                 BorderBrush="#2E2E2E"
                                 Foreground="White"
                                 Height="70"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom buttons -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Save &amp; New"
                    Width="120"
                    Height="30"
                    HorizontalAlignment="Left"
                    Click="SaveAndNew_Click"/>

            <Button Grid.Column="1"
                    Content="Save"
                    Width="110"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>

            <Button Grid.Column="2"
                    Content="Cancel"
                    Width="110"
                    Height="30"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
