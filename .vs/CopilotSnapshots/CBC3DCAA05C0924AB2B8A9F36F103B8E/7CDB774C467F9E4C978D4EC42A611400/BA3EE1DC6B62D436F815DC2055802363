<Window x:Class="PointofSale.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory - Item List"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
		UseLayoutRounding="True"
		SnapsToDevicePixels="True"
		TextOptions.TextFormattingMode="Display"
		TextOptions.TextRenderingMode="ClearType">

	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Header -->
		<Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,12">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="360"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<StackPanel>
					<TextBlock Text="Item List" FontSize="22" FontWeight="Bold"/>
					<TextBlock Text="Add, edit, and manage stock"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"/>
				</StackPanel>

				<!-- Search -->
				<TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         Margin="12,0,12,0"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource HintTextBox}"
                         Tag="Search inventory..."
                         TextChanged="SearchBox_TextChanged"/>

				<!-- Actions -->
				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
					<Button Style="{StaticResource ModernButton}"
                            Content="Refresh"
                            Margin="0,0,8,0"
                            Click="RefreshBtn_Click"/>

					<Button Style="{StaticResource ModernButton}"
                            Content="Add"
                            Margin="0,0,8,0"
                            Click="AddBtn_Click"/>

					<Button Style="{StaticResource ModernButton}"
                            Content="Edit"
                            Margin="0,0,8,0"
                            Click="EditBtn_Click"/>

					<Button Style="{StaticResource ModernButton}"
                            Content="Delete"
                            Click="DeleteBtn_Click"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Body -->
		<Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<DataGrid x:Name="ProductsGrid"
                          Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Vertical"
                          EnableRowVirtualization="False"
                          EnableColumnVirtualization="False"
                          ColumnWidth="Auto"
                          Background="{StaticResource PanelBrush}"
                          Foreground="White"
                          RowBackground="{StaticResource PanelBrush}"
                          AlternatingRowBackground="{StaticResource Panel2Brush}"
                          BorderThickness="0"
                          SelectionMode="Single"
					  UseLayoutRounding="True"
					  SnapsToDevicePixels="True"
                          SelectionChanged="ProductsGrid_SelectionChanged"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick">

					<DataGrid.Resources>

						<!-- Column headers -->
						<Style TargetType="DataGridColumnHeader">
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="Background" Value="#171717"/>
							<Setter Property="BorderBrush" Value="#2E2E2E"/>
							<Setter Property="BorderThickness" Value="0,0,0,1"/>
							<Setter Property="FontWeight" Value="SemiBold"/>
							<Setter Property="Padding" Value="10,8"/>
							<Setter Property="HorizontalContentAlignment" Value="Center"/>
						</Style>

						<!-- Rows -->
						<Style TargetType="DataGridRow">
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="FontSize" Value="13"/>
							<Setter Property="MinHeight" Value="32"/>
							<Setter Property="Background" Value="{StaticResource PanelBrush}"/>
							<Setter Property="BorderBrush" Value="#2E2E2E"/>
							<Setter Property="BorderThickness" Value="0,0,0,1"/>
							<Style.Triggers>
								<!-- Selected row -->
								<Trigger Property="IsSelected" Value="True">
									<Setter Property="Background" Value="#FFC107"/>
									<!-- gold -->
									<Setter Property="Foreground" Value="Black"/>
								</Trigger>

								<!-- Mouse hover -->
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#252525"/>
								</Trigger>
							</Style.Triggers>
						</Style>

						<!-- Cells -->
						<Style TargetType="DataGridCell">
							<Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}"/>
							<Setter Property="Padding" Value="10,8"/>
							<Setter Property="BorderThickness" Value="0"/>
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="VerticalContentAlignment" Value="Center"/>
							<Setter Property="HorizontalContentAlignment" Value="Center"/>
							<Style.Triggers>
								<!-- Selected cell (keeps text readable) -->
								<Trigger Property="IsSelected" Value="True">
									<Setter Property="Foreground" Value="Black"/>
								</Trigger>
							</Style.Triggers>
						</Style>

					</DataGrid.Resources>


					<DataGrid.Columns>
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Item #" />
									<TextBox x:Name="IdFilterBox" Tag="Id" Width="60" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Id" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Item Name" />
									<TextBox x:Name="NameFilterBox" Tag="Name" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Name" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
									<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- Department -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Department" />
									<TextBox x:Name="DeptFilterBox" Tag="Department" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Department" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
									<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- Description -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Item Description" />
									<TextBox x:Name="DescFilterBox" Tag="Description" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Description" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
									<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- Size -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Size" />
									<TextBox x:Name="SizeFilterBox" Tag="Size" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Size" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- Regular Price -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Regular Price" />
									<TextBox x:Name="PriceFilterBox" Tag="Price" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="Price" StringFormat="R {0:0.00}"/>
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- On-hand Qty -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="On-hand Qty" />
									<TextBox x:Name="StockFilterBox" Tag="StockQty" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="StockQty" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- SKU -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="SKU" />
									<TextBox x:Name="SkuFilterBox" Tag="SKU" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="SKU" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
									<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- ALU -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="Alternate Lookup" />
									<TextBox x:Name="AluFilterBox" Tag="ALU" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="ALU" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>

						<!-- O/H Qty -->
						<DataGridTextColumn>
							<DataGridTextColumn.Header>
								<StackPanel>
									<TextBlock Text="O/H Qty" />
									<TextBox x:Name="OhFilterBox" Tag="StockQty" Height="22" Margin="0,6,0,0" TextChanged="ColumnFilter_TextChanged"
										Background="#222" Foreground="White" BorderBrush="#333"/>
								</StackPanel>
							</DataGridTextColumn.Header>
							<DataGridTextColumn.Binding>
								<Binding Path="StockQty" />
							</DataGridTextColumn.Binding>
							<DataGridTextColumn.ElementStyle>
								<Style TargetType="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
								</Style>
							</DataGridTextColumn.ElementStyle>
						</DataGridTextColumn>
					</DataGrid.Columns>
				</DataGrid>

				<TextBlock Grid.Row="1"
                           x:Name="MsgText"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="2,10,2,0"
                           TextWrapping="Wrap"/>
			</Grid>
		</Border>
	</Grid>
</Window>
