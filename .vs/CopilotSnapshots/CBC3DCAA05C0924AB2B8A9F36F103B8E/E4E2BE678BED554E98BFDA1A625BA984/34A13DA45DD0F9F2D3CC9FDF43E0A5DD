using System.Configuration;
using System.Data;
using System.Windows;
using PointofSale.Views;

namespace PointofSale
{
    /// <summary>
    /// Interaction logic for App.xaml
    /// </summary>
    public partial class App : Application
    {
        protected override void OnStartup(StartupEventArgs e)
        {
            base.OnStartup(e);

            // Show login window instead of the default StartupUri
            LoginWindow login = new LoginWindow();
            if (login.ShowDialog() == true)
            {
                // If login successful, show admin dashboard
                AdminDashboardWindow dashboard = new AdminDashboardWindow();
                dashboard.Show();
            }
            else
            {
                // If login cancelled, shut down the app
                this.Shutdown();
            }
        }
    }
}
