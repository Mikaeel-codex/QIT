<Window x:Class="PointofSale.PostSaleActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt Options"
        Width="460"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111"
        Foreground="White">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Choose receipt method" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Select ONE option, then Continue."
                       Opacity="0.75" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#151515" CornerRadius="12" Padding="14" Margin="0,16,0,16">
            <StackPanel>
                <RadioButton x:Name="PrintRb"
                             GroupName="ReceiptOption"
                             Content="Print"
                             FontSize="14"
                             Margin="0,0,0,10"
                             Checked="Option_Checked"/>

                <RadioButton x:Name="WhatsAppRb"
                             GroupName="ReceiptOption"
                             Content="Send on WhatsApp"
                             FontSize="14"
                             Margin="0,0,0,10"
                             Checked="Option_Checked"/>

                <RadioButton x:Name="EmailRb"
                             GroupName="ReceiptOption"
                             Content="Send on Email"
                             FontSize="14"
                             Checked="Option_Checked"/>

                <TextBlock x:Name="HintText"
                           Margin="0,12,0,0"
                           Opacity="0.75"
                           Text=""/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="110" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button x:Name="ContinueBtn" Content="Continue" Width="110" IsEnabled="False" Click="Continue_Click"/>
        </StackPanel>
    </Grid>
</Window>
