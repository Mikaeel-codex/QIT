<Window x:Class="PointofSale.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Inventory Till"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Loaded="MainWindow_Loaded">

    <Window.Resources>

        <Style x:Key="ProfileMenuItem" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#E0E0E0"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="14,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#F4C542"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileMenuItemDanger" TargetType="Button"
               BasedOn="{StaticResource ProfileMenuItem}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF6B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid PreviewMouseLeftButtonDown="MainGrid_PreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOP NAVBAR ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,0" Height="52">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                    <Border Width="43" Height="41" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <ImageBrush ImageSource="/QIT Logo.png"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Quick Inventory Till" FontSize="15"
                               FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Sidebar hamburger -->

                <!-- Welcome -->
                <TextBlock Grid.Column="2" x:Name="WelcomeTxt"
                           Text="Welcome back!" Foreground="White"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- Clock -->
                <TextBlock Grid.Column="3" x:Name="ClockTxt"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- Bell -->

                <!-- ══ PROFILE AREA ══ -->
                <Grid Grid.Column="5" VerticalAlignment="Center">

                    <!-- Avatar + Name + Hamburger button in one row -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,4,0,4">

                        <!-- Avatar -->
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{DynamicResource GoldBrush}" Margin="0,0,9,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="NavAvatarTxt" Text="?"
                                       Foreground="#111111" FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + Role -->
                        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="NavUserNameTxt" Text="Sign In"
                                       Foreground="White" FontSize="13"
                                       FontWeight="SemiBold" MaxWidth="130"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="NavUserRoleTxt" Text=""
                                       Foreground="#AFAFAF" FontSize="11"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <!-- ══ HAMBURGER BUTTON
                             Lines live here in normal XAML so code-behind can
                             access them by x:Name directly. The ToggleButton
                             is just a transparent hit-target layered on top.   ══ -->
                        <Grid Width="32" Height="32" VerticalAlignment="Center">

                            <!-- The three lines (named so code-behind can animate them) -->
                            <Viewbox Width="20" Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsHitTestVisible="False">
                                <Canvas Width="32" Height="32">

                                    <!-- Line 1 (top) -->
                                    <Line x:Name="Line1"
                                          X1="6" Y1="10" X2="26" Y2="10"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform x:Name="Line1Rotate"
                                                                 Angle="0"
                                                                 CenterX="16" CenterY="10"/>
                                                <TranslateTransform x:Name="Line1Translate" Y="0"/>
                                            </TransformGroup>
                                        </Line.RenderTransform>
                                    </Line>

                                    <!-- Line 2 (middle) -->
                                    <Line x:Name="Line2"
                                          X1="6" Y1="16" X2="26" Y2="16"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>

                                    <!-- Line 3 (bottom) -->
                                    <Line x:Name="Line3"
                                          X1="6" Y1="22" X2="26" Y2="22"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform x:Name="Line3Rotate"
                                                                 Angle="0"
                                                                 CenterX="16" CenterY="22"/>
                                                <TranslateTransform x:Name="Line3Translate" Y="0"/>
                                            </TransformGroup>
                                        </Line.RenderTransform>
                                    </Line>

                                </Canvas>
                            </Viewbox>

                            <!-- Transparent Button on top as the click target -->
                            <Button x:Name="ProfileToggle"
                                    Width="32" Height="32"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0.01"
                                    Cursor="Hand"
                                    Click="ProfileBtn_Click"/>

                            <!-- Hover highlight behind lines -->
                            <Border x:Name="HamburgerHover"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <!-- ══ END HAMBURGER ══ -->

                    </StackPanel>

                    <!-- ══ DROPDOWN POPUP ══ -->
                    <Popup x:Name="ProfilePopup"
                           PlacementTarget="{Binding ElementName=ProfileToggle}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">

                        <Border Background="#1B1B1B"
                                BorderBrush="#2E2E2E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0,8,0,8"
                                MinWidth="230">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.5"
                                                  BlurRadius="20" ShadowDepth="4"
                                                  Direction="270"/>
                            </Border.Effect>

                            <StackPanel>

                                <!-- Header -->
                                <Border Padding="14,10,14,12"
                                        BorderBrush="#2E2E2E"
                                        BorderThickness="0,0,0,1"
                                        Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="#F4C542" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupAvatarTxt" Text="?"
                                                       Foreground="#111111" FontSize="15"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupUserNameTxt" Text="Sign In"
                                                       Foreground="White" FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="PopupUserRoleTxt" Text=""
                                                       Foreground="#AFAFAF" FontSize="12"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Menu items -->
                                <StackPanel Margin="6,0,6,0">

                                    <Button x:Name="SignInMenuItem"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Visibility="Collapsed"
                                            Click="SignInMenuItem_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔑" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sign In" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="MyAccountMenuItem"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Click="MyAccount_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="My Account" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="Subscription"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Click="Subscription_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💳" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Subscription" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Separator x:Name="MenuSeparator"
                                               Background="#2E2E2E" Margin="8,4,8,4"/>

                                    <Button x:Name="HelpCenterMenuItem"
                                                    Style="{StaticResource ProfileMenuItem}"
                                                    Click="HelpCenter_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="❓" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Help Center" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Separator Background="#2E2E2E" Margin="8,4,8,4"/>

                                    <!-- Sign Out button here -->

                                    <Button x:Name="SignOutMenuItem"
                                            Style="{StaticResource ProfileMenuItemDanger}"
                                            Click="SignOut_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⏻" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sign Out" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
                <!-- ══ END PROFILE AREA ══ -->

            </Grid>
        </Border>

        <!-- ══ TILE GRID ══ -->
        <Grid Grid.Row="1" x:Name="MainGrid">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <UniformGrid x:Name="TileGrid" Columns="4"
                             Margin="60,30,60,30"
                             VerticalAlignment="Center">

                    <!-- Make a Sale -->
                    <Border x:Name="MakeSaleTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="MakeSaleBtn" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="MakeSale_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Make A sale.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Make a Sale"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="MakeSaleUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Held Receipts -->
                    <Border x:Name="HeldReceiptsTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="HeldReceiptsBtn" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="HeldReceipts_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Held Receipts.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Held Receipts"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="HeldReceiptsUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Sales History -->
                    <Border x:Name="SalesHistoryTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="SalesHistoryBtn" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="SalesHistory_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/sales History.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Sales History"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="SalesHistoryUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Inventory -->
                    <Border x:Name="InventoryTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="ProductsBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Products_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Inventory.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Inventory"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="InventoryUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Sales Orders -->
                    <Border x:Name="SalesOrderTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="SalesOrderBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="SalesOrder_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Sales Order.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Sales Orders"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="SalesOrderUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Order List -->
                    <Border x:Name="OrderListTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="OrderListBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="OrderList_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Sales Order List.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Order List"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="OrderListUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Receive Stock -->
                    <Border x:Name="ReceiveStockTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="ReceiveStockBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="ReceiveStock_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Receive stock.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Receive Stock"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="ReceiveStockUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Customers -->
                    <Border x:Name="CustomersTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="CustomersListBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="CustomersList_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Customers.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Customers"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="CustomersUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Employees / Users -->
                    <Border x:Name="EmployeesTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="EmployeesBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Users_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Emplyees.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Employees / Users"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="EmployeesUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Reports -->
                    <Border x:Name="ReportsTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="ReportsBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Reports_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Report.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Reports"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="ReportsUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- End of Day -->
                    <Border x:Name="EndOfDayTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="EndOfDayBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="EndOfDay_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/End of Day.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="End of Day"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="EndOfDayUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Suppliers -->
                    <Border x:Name="SuppliersTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="SupplierTileBtn" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Supplier_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/manufacture.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Suppliers"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="SuppliersUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Departments -->
                    <Border x:Name="DepartmentsTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="DepartmentsTileBtn" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Departments_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/Department.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Departments"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="DepartmentsUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Settings — centred solo tile -->
                    <Border x:Name="SettingsTile"
                            Margin="0,0,0,32"
                            MouseEnter="Tile_MouseEnter"
                            MouseLeave="Tile_MouseLeave">
                        <Button x:Name="SettingsBtn_Tile" Style="{StaticResource TileButton}"
                                HorizontalContentAlignment="Center"
                                Click="Settings_Click" Padding="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="/icons/settings.png"
                                       Width="100" Height="100"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14"/>
                                <TextBlock Text="Settings"
                                           Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>
                                <Border x:Name="SettingsUnderline"
                                        Height="3" Width="40" CornerRadius="2"
                                        Background="#2F66C8"
                                        HorizontalAlignment="Center"
                                        Opacity="0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
