<Window x:Class="PointofSale.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Inventory Till"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Loaded="MainWindow_Loaded">

    <Window.Resources>

        <Style x:Key="ProfileMenuItem" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#E0E0E0"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="14,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#242424"/>
                                <Setter Property="Foreground" Value="#F4C542"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileMenuItemDanger" TargetType="Button"
               BasedOn="{StaticResource ProfileMenuItem}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF6B6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid PreviewMouseLeftButtonDown="MainGrid_PreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ TOP NAVBAR ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,0" Height="52">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                    <Border Width="43" Height="41" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <ImageBrush ImageSource="/QIT Logo.png"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Quick Inventory Till" FontSize="15"
                               FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Sidebar hamburger -->

                <!-- Welcome -->
                <TextBlock Grid.Column="2" x:Name="WelcomeTxt"
                           Text="Welcome back!" Foreground="White"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <!-- Clock -->
                <TextBlock Grid.Column="3" x:Name="ClockTxt"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- Bell -->

                <!-- ══ PROFILE AREA ══ -->
                <Grid Grid.Column="5" VerticalAlignment="Center">

                    <!-- Avatar + Name + Hamburger button in one row -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,4,0,4">

                        <!-- Avatar -->
                        <Border Width="34" Height="34" CornerRadius="17"
                                Background="{DynamicResource GoldBrush}" Margin="0,0,9,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="NavAvatarTxt" Text="?"
                                       Foreground="#111111" FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + Role -->
                        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="NavUserNameTxt" Text="Sign In"
                                       Foreground="White" FontSize="13"
                                       FontWeight="SemiBold" MaxWidth="130"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="NavUserRoleTxt" Text=""
                                       Foreground="#AFAFAF" FontSize="11"
                                       Margin="0,1,0,0"/>
                        </StackPanel>

                        <!-- ══ HAMBURGER BUTTON
                             Lines live here in normal XAML so code-behind can
                             access them by x:Name directly. The ToggleButton
                             is just a transparent hit-target layered on top.   ══ -->
                        <Grid Width="32" Height="32" VerticalAlignment="Center">

                            <!-- The three lines (named so code-behind can animate them) -->
                            <Viewbox Width="20" Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsHitTestVisible="False">
                                <Canvas Width="32" Height="32">

                                    <!-- Line 1 (top) -->
                                    <Line x:Name="Line1"
                                          X1="6" Y1="10" X2="26" Y2="10"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform x:Name="Line1Rotate"
                                                                 Angle="0"
                                                                 CenterX="16" CenterY="10"/>
                                                <TranslateTransform x:Name="Line1Translate" Y="0"/>
                                            </TransformGroup>
                                        </Line.RenderTransform>
                                    </Line>

                                    <!-- Line 2 (middle) -->
                                    <Line x:Name="Line2"
                                          X1="6" Y1="16" X2="26" Y2="16"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>

                                    <!-- Line 3 (bottom) -->
                                    <Line x:Name="Line3"
                                          X1="6" Y1="22" X2="26" Y2="22"
                                          Stroke="#AFAFAF"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round">
                                        <Line.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform x:Name="Line3Rotate"
                                                                 Angle="0"
                                                                 CenterX="16" CenterY="22"/>
                                                <TranslateTransform x:Name="Line3Translate" Y="0"/>
                                            </TransformGroup>
                                        </Line.RenderTransform>
                                    </Line>

                                </Canvas>
                            </Viewbox>

                            <!-- Transparent Button on top as the click target -->
                            <Button x:Name="ProfileToggle"
                                    Width="32" Height="32"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0.01"
                                    Cursor="Hand"
                                    Click="ProfileBtn_Click"/>

                            <!-- Hover highlight behind lines -->
                            <Border x:Name="HamburgerHover"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        <!-- ══ END HAMBURGER ══ -->

                    </StackPanel>

                    <!-- ══ DROPDOWN POPUP ══ -->
                    <Popup x:Name="ProfilePopup"
                           PlacementTarget="{Binding ElementName=ProfileToggle}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">

                        <Border Background="#1B1B1B"
                                BorderBrush="#2E2E2E"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="0,8,0,8"
                                MinWidth="230">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.5"
                                                  BlurRadius="20" ShadowDepth="4"
                                                  Direction="270"/>
                            </Border.Effect>

                            <StackPanel>

                                <!-- Header -->
                                <Border Padding="14,10,14,12"
                                        BorderBrush="#2E2E2E"
                                        BorderThickness="0,0,0,1"
                                        Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="#F4C542" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupAvatarTxt" Text="?"
                                                       Foreground="#111111" FontSize="15"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="PopupUserNameTxt" Text="Sign In"
                                                       Foreground="White" FontSize="14"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="PopupUserRoleTxt" Text=""
                                                       Foreground="#AFAFAF" FontSize="12"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Menu items -->
                                <StackPanel Margin="6,0,6,0">

                                    <Button x:Name="SignInMenuItem"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Visibility="Collapsed"
                                            Click="SignInMenuItem_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔑" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sign In" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="MyAccountMenuItem"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Click="MyAccount_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="👤" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="My Account" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="Subscription"
                                            Style="{StaticResource ProfileMenuItem}"
                                            Click="Subscription_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💳" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Subscription" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Separator x:Name="MenuSeparator"
                                               Background="#2E2E2E" Margin="8,4,8,4"/>

                                    <Button x:Name="HelpCenterMenuItem"
                                                    Style="{StaticResource ProfileMenuItem}"
                                                    Click="HelpCenter_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="❓" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Help Center" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Separator Background="#2E2E2E" Margin="8,4,8,4"/>

                                    <!-- Sign Out button here -->

                                    <Button x:Name="SignOutMenuItem"
                                            Style="{StaticResource ProfileMenuItemDanger}"
                                            Click="SignOut_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⏻" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sign Out" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                </Grid>
                <!-- ══ END PROFILE AREA ══ -->

            </Grid>
        </Border>

        <!-- ══ TILE GRID ══ -->
        <Grid Grid.Row="1" Margin="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="4" Margin="0,0,0,10">

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="MakeSaleBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="MakeSale_Click">
                            <StackPanel>
                                <TextBlock Text="🛒  Make a Sale" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Open POS screen" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="HeldReceiptsBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="HeldReceipts_Click">
                            <StackPanel>
                                <TextBlock Text="📋 Held Receipts" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="View Held receipts &amp; totals" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="SalesHistoryBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="SalesHistory_Click">
                            <StackPanel>
                                <TextBlock Text="📒  Sales History" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="View receipts &amp; totals" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="ProductsBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Products_Click">
                            <StackPanel>
                                <TextBlock Text="📦  Inventory" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage products &amp; stock" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="ReceiveStockBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="ReceiveStock_Click">
                            <StackPanel>
                                <TextBlock Text="📥  Receive Stock" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Record incoming inventory" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="CustomersListBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="CustomersList_Click">
                            <StackPanel>
                                <TextBlock Text="👥  Customers" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Customer list &amp; details" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="EmployeesBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Users_Click">
                            <StackPanel>
                                <TextBlock Text="🧑‍💼  Employees / Users" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Cashiers, roles, access" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="ReportsBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Reports_Click">
                            <StackPanel>
                                <TextBlock Text="📊  Reports" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Performance &amp; analytics" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="EndOfDayBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="EndOfDay_Click">
                            <StackPanel>
                                <TextBlock Text="🧾  End of Day" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Close out daily totals" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="SupplierTileBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Supplier_Click">
                            <StackPanel>
                                <TextBlock Text="🏢  Supplier" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Manage supplier records" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="DepartmentsTileBtn" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Departments_Click">
                            <StackPanel>
                                <TextBlock Text="🗂️  Departments" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Set department categories" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Margin="0,0,12,12" CornerRadius="16"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Padding="14">
                        <Button x:Name="SettingsBtn_Tile" Style="{StaticResource ModernButton}"
                                HorizontalContentAlignment="Left" Padding="10" Click="Settings_Click">
                            <StackPanel>
                                <TextBlock Text="⚙️  Settings" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="System configuration" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </Border>

                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
