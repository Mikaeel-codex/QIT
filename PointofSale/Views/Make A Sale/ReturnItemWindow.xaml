<Window x:Class="PointofSale.Views.ReturnItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Return Item"
        Width="460" Height="533"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="White">

    <Border Padding="24">
        <StackPanel>

            <!-- Title -->
            <TextBlock Text="Return Item" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
            <TextBlock x:Name="ItemNameTxt" Foreground="#B8B8B8" FontSize="13" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <!-- Receipt number row -->
            <TextBlock Text="Original Receipt Number" Foreground="#B8B8B8" FontSize="11" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ReceiptNoBox"
                         Grid.Column="0"
                         Height="36"
                         KeyDown="ReceiptNoBox_KeyDown"/>
                <Button x:Name="LookupBtn"
                        Grid.Column="2"
                        Content="Look Up"
                        Style="{StaticResource ModernButton}"
                        Height="36" Padding="14,0"
                        Click="LookupBtn_Click"/>
            </Grid>

            <!-- Result panel — hidden until lookup -->
            <Border x:Name="ResultPanel"
                    Visibility="Collapsed"
                    Background="#1B1B1B"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,12"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock x:Name="SaleDateTxt"  Foreground="#B8B8B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SaleTotalTxt" Foreground="#B8B8B8" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ItemFoundTxt" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Reason for return -->
            <TextBlock Text="Reason for Return" Foreground="#B8B8B8" FontSize="11" Margin="0,4,0,4"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ReasonBox" Grid.Column="0" Height="36">
                    <ComboBoxItem Content="Damaged / Defective"  IsSelected="True"/>
                    <ComboBoxItem Content="Wrong Item"/>
                    <ComboBoxItem Content="Changed Mind"/>
                    <ComboBoxItem Content="Wrong Size / Variant"/>
                    <ComboBoxItem Content="Expired / Spoiled"/>
                    <ComboBoxItem Content="Duplicate Purchase"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>
                <TextBox x:Name="ReasonNotesBox"
                         Grid.Column="2"
                         Height="36"
                         Tag="Additional notes (optional)"
                         Style="{StaticResource HintTextBox}"/>
            </Grid>

            <!-- Error -->
            <TextBlock x:Name="ErrorTxt"
                       Foreground="#D9534F"
                       FontSize="12"
                       Margin="0,0,0,12"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel"
                        Style="{StaticResource ModernButton}"
                        Height="38" Click="Cancel_Click"/>
                <Button x:Name="ConfirmBtn"
                        Grid.Column="2"
                        Content="Confirm Return"
                        Style="{StaticResource GoldButton}"
                        Height="38"
                        IsEnabled="False"
                        Click="Confirm_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
