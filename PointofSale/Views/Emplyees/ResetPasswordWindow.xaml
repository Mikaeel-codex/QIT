<Window x:Class="PointofSale.Views.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Width="380" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <StackPanel Margin="24,20,24,16">

        <TextBlock x:Name="HeaderTxt"
                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="New Password" Foreground="White" FontSize="12" Margin="0,0,0,4"/>
        <PasswordBox x:Name="NewPassBox" Height="28" Padding="6,2" Margin="0,0,0,12"/>

        <TextBlock Text="Confirm Password" Foreground="White" FontSize="12" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmPassBox" Height="28" Padding="6,2" Margin="0,0,0,12"/>

        <TextBlock x:Name="ErrorTxt" Foreground="#FF5555" FontSize="11"
                   Visibility="Collapsed" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Reset Password"
                    Width="130" Height="32" Margin="0,0,10,0"
                    Background="#2F66C8" Foreground="White"
                    BorderBrush="#1F4E9A" BorderThickness="1"
                    Cursor="Hand" Click="ResetBtn_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="32"
                    Background="{StaticResource Panel2Brush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Foreground="White" Cursor="Hand"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
