<Window x:Class="PointofSale.Views.StoreSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="860" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="700" MinHeight="480"
        Background="#111111"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="#BBBBBB"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Height"                     Value="42"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="16,0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
        </Style>
        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background"      Value="#1E1E1E"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="BorderBrush"     Value="#2F66C8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Grid Grid.Column="0" Background="#0D0D0D">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,14"
                    BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="15" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="System configuration" Foreground="#555555" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Nav -->
            <StackPanel Grid.Row="1" Margin="0,8,0,0">

                <TextBlock Text="STORE" Foreground="#444444" FontSize="10"
                           FontWeight="Bold" Margin="16,8,0,4"/>

                <Button x:Name="NavStoreInfo"
                        Style="{StaticResource NavBtnActive}"
                        Click="Nav_Click"
                        Tag="StoreInfo">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏪" FontSize="13" Margin="0,0,10,0"/>
                        <TextBlock Text="Store &amp; Email"/>
                    </StackPanel>
                </Button>

                <Button x:Name="NavReceipt"
                        Style="{StaticResource NavBtn}"
                        Click="Nav_Click"
                        Tag="Receipt">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧾" FontSize="13" Margin="0,0,10,0"/>
                        <TextBlock Text="Receipt"/>
                    </StackPanel>
                </Button>

                <TextBlock Text="SYSTEM" Foreground="#444444" FontSize="10"
                           FontWeight="Bold" Margin="16,16,0,4"/>

                <Button x:Name="NavTax"
                        Style="{StaticResource NavBtn}"
                        Click="Nav_Click"
                        Tag="Tax">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💰" FontSize="13" Margin="0,0,10,0"/>
                        <TextBlock Text="Tax"/>
                    </StackPanel>
                </Button>

                <Button x:Name="NavPrinter"
                        Style="{StaticResource NavBtn}"
                        Click="Nav_Click"
                        Tag="Printer">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖨" FontSize="13" Margin="0,0,10,0"/>
                        <TextBlock Text="Printer"/>
                    </StackPanel>
                </Button>

                <Button x:Name="NavTheme"
                        Style="{StaticResource NavBtn}"
                        Click="Nav_Click"
                        Tag="Theme">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎨" FontSize="13" Margin="0,0,10,0"/>
                        <TextBlock Text="Appearance"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Close -->
            <Button Grid.Row="2"
                    Content="Close"
                    Background="Transparent"
                    Foreground="#666666"
                    BorderThickness="0"
                    FontSize="12"
                    Height="40"
                    Cursor="Hand"
                    HorizontalContentAlignment="Left"
                    Padding="16,0"
                    Margin="0,0,0,8"
                    Click="Close_Click"/>
        </Grid>

        <!-- RIGHT CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page header -->
            <Border Grid.Row="0" Background="#0D0D0D" Padding="24,14"
                    BorderBrush="#1E1E1E" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock x:Name="PageTitle"
                               Text="Store &amp; Email"
                               FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="PageSubtitle"
                               Text="Your store details and email configuration."
                               Foreground="#555555" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content frame -->
            <Frame x:Name="ContentFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>

    </Grid>
</Window>
