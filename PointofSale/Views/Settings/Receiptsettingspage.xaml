<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="PointofSale.Views.Settings.ReceiptSettingsPage"
      Background="#111111" av:DesignWidth="476.584" av:DesignHeight="352.689">

    <Page.Resources>
        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background"               Value="#1A1A1A"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderBrush"              Value="#333333"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="32"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="Margin"                   Value="0,0,0,14"/>
        </Style>
        <Style x:Key="HintText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,-10,0,14"/>
        </Style>
        <Style x:Key="SaveBtn" TargetType="{x:Type Button}">
            <Setter Property="Background"      Value="#2F66C8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#1F4E9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="24,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Receipt Number Prefix (e.g. INV, REC)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtPrefix" Style="{StaticResource InputBox}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="Receipts will be e.g. INV-0001, INV-0002"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Next Receipt Number" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtNextNumber" Style="{StaticResource InputBox}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="Auto-increments after each sale."/>
                    </StackPanel>
                </Grid>

                <Separator Background="#222222" Margin="0,4,0,20"/>

                <TextBlock Text="Receipt Footer Message" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFooter"
                         Style="{StaticResource InputBox}"
                         Height="70"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         Padding="8,6"/>
                <TextBlock Style="{StaticResource HintText}"
                           Text="This message appears at the bottom of every receipt PDF."/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#0D0D0D" Padding="24,12"
                BorderBrush="#1E1E1E" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTxt" VerticalAlignment="Center"
                           FontSize="12" Foreground="#88CC66"
                           Visibility="Collapsed"/>
                <Button Grid.Column="1" Content="Save Settings"
                        Style="{StaticResource SaveBtn}"
                        Click="Save_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
