<Page x:Class="PointofSale.Views.Settings.ThemePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111111"
      Foreground="White">

    <Page.Resources>

        <Style x:Key="ThemeCard" TargetType="Border">
            <Setter Property="Width"          Value="150"/>
            <Setter Property="Height"         Value="160"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin"         Value="0,0,16,16"/>
            <Setter Property="Cursor"         Value="Hand"/>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="Appearance"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Choose a colour theme. Changes apply instantly."
                       Foreground="#666666"
                       FontSize="12"
                       Margin="0,0,0,24"/>

            <!-- Theme swatches -->
            <WrapPanel>

                <!-- Dark (default) -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardDark"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Dark">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#111111" Offset="0"/>
                                <GradientStop Color="#1B1B1B" Offset="0.5"/>
                                <GradientStop Color="#222222" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelDark"
                               Text="Dark (Default)"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Forest -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardForest"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Forest">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#0D1F17" Offset="0"/>
                                <GradientStop Color="#163324" Offset="0.4"/>
                                <GradientStop Color="#1E4232" Offset="0.7"/>
                                <GradientStop Color="#3A8C5C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelForest"
                               Text="Forest"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Ocean -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardOcean"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Ocean">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1E1B4B" Offset="0"/>
                                <GradientStop Color="#252272" Offset="0.4"/>
                                <GradientStop Color="#3A7CA5" Offset="0.7"/>
                                <GradientStop Color="#EEFFCC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelOcean"
                               Text="Ocean"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Blossom -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardBlossom"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Blossom">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF70A6" Offset="0"/>
                                <GradientStop Color="#E8A0BF" Offset="0.5"/>
                                <GradientStop Color="#FADADD" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelBlossom"
                               Text="Blossom"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Candy -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardCandy"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Candy">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F9A8D4" Offset="0"/>
                                <GradientStop Color="#FEF08A" Offset="0.5"/>
                                <GradientStop Color="#7DD3FC" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelCandy"
                               Text="Candy"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Mocha -->
                <StackPanel Margin="0,0,20,20">
                    <Border x:Name="CardMocha"
                            Width="150" Height="120"
                            CornerRadius="10"
                            BorderThickness="3"
                            Cursor="Hand"
                            MouseLeftButtonUp="Theme_Click"
                            Tag="Mocha">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFF8F0" Offset="0"/>
                                <GradientStop Color="#C68642" Offset="0.5"/>
                                <GradientStop Color="#5C3D1E" Offset="0.8"/>
                                <GradientStop Color="#2E1A0E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock x:Name="LabelMocha"
                               Text="Mocha"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

            </WrapPanel>

            <!-- Status -->
            <TextBlock x:Name="StatusTxt"
                       Foreground="#88CC66"
                       FontSize="12"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Page>
