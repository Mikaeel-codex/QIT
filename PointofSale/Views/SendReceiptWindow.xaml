<Window x:Class="PointofSale.Views.SendReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Receipt"
        Width="420" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"               Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="32"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="CaretBrush"               Value="White"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="16,0"/>
        </Style>
        <Style x:Key="OptionCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="12,10"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border Padding="20">
        <StackPanel>

            <TextBlock Text="Send Receipt" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubtitleTxt"
                       Text="Choose how to send the receipt to the customer."
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12" Margin="0,0,0,16"/>

            <!-- Email option -->
            <Border Style="{StaticResource OptionCard}">
                <StackPanel>
                    <CheckBox x:Name="ChkEmail" Foreground="White" FontSize="13"
                              FontWeight="SemiBold" Margin="0,0,0,8"
                              Checked="Option_Changed" Unchecked="Option_Changed">
                        <TextBlock Text="Send via Email" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </CheckBox>
                    <StackPanel x:Name="EmailFields" Visibility="Collapsed">
                        <TextBlock Text="Email address" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="EmailBox" Style="{StaticResource InputBox}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- WhatsApp option -->
            <Border Style="{StaticResource OptionCard}">
                <StackPanel>
                    <CheckBox x:Name="ChkWhatsApp" Foreground="White" FontSize="13"
                              FontWeight="SemiBold" Margin="0,0,0,8"
                              Checked="Option_Changed" Unchecked="Option_Changed">
                        <TextBlock Text="Send via WhatsApp" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </CheckBox>
                    <StackPanel x:Name="WhatsAppFields" Visibility="Collapsed">
                        <TextBlock Text="WhatsApp number (with country code)" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="WhatsAppBox" Style="{StaticResource InputBox}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusTxt"
                       Foreground="#E53935"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="BtnSend"
                        Content="Send Receipt"
                        Style="{StaticResource ActionBtn}"
                        Margin="0,0,8,0"
                        Click="Send_Click"/>

                <Button Grid.Column="2"
                        Content="Skip"
                        Style="{StaticResource ActionBtn}"
                        Background="{StaticResource Panel2Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        Click="Skip_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
