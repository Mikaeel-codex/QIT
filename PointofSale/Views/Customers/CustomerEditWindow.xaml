<Window x:Class="PointofSale.Views.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Customer"
        Width="940" Height="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Customer Info header -->
            <RowDefinition Height="*"/>
            <!-- Blocks -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══ TOP: CUSTOMER INFO ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="12"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Customer Info"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                </DockPanel>

                <!-- Full Name row -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="First  &amp;  Last Name"
                               VerticalAlignment="Center"
                               Foreground="White" FontSize="12"/>
                    <TextBox x:Name="FirstNameBox"
                             Grid.Column="1"
                             Height="28" Padding="6,2"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBox x:Name="LastNameBox"
                             Grid.Column="3"
                             Height="28" Padding="6,2"/>
                    <TextBlock Grid.Column="4"
                               Text="*" Foreground="Red" FontSize="14"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </Grid>

                <!-- Phone / Email row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Phone"
                               VerticalAlignment="Center"
                               Foreground="White" FontSize="12"/>
                    <TextBox x:Name="PhoneBox"
                             Grid.Column="1"
                             Height="28" Padding="6,2"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3"
                               Text="Email"
                               VerticalAlignment="Center"
                               Foreground="White" FontSize="12"/>
                    <TextBox x:Name="EmailBox"
                             Grid.Column="4"
                             Height="28" Padding="6,2"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ MIDDLE: BLOCKS ═══ -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <!-- Contact / Address -->
                <ColumnDefinition Width="300"/>
                <!-- Account & Credit -->
                <ColumnDefinition Width="*"/>
                <!-- Notes -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── ADDRESS ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,10,0"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Address"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Street" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="AddressBox" Height="26" Padding="6,1"/>

                        <TextBlock Grid.Row="1" Text="City" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="CityBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="Province" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ProvinceBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="3" Text="Postal Code" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="PostalCodeBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── ACCOUNT & CREDIT ── -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,10,260"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Account &amp; Credit"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Account Bal." Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="AccountBalanceBox" Height="26" Padding="6,1" Text="0.00"/>

                        <TextBlock Grid.Row="1" Text="Credit Limit" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="CreditLimitBox" Height="26" Padding="6,1" Margin="0,10,0,0" Text="0.00"/>

                        <Separator Grid.Row="2" Grid.ColumnSpan="2"
                                   Background="{StaticResource BorderBrush}"
                                   Margin="0,14,0,10"/>

                        <!-- Available credit (read-only display) -->
                        <TextBlock Grid.Row="3" Text="Available" Foreground="{StaticResource MutedBrush}" FontSize="14" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="AvailableCreditBox"
                                   Height="26" Padding="6,1"
                                   IsReadOnly="True"
                                   Text="0.00"
                                   Foreground="#88CC66"/>

                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="InactiveCheck"
                                  Content="Inactive"
                                  Margin="0,64,0,-46"
                                  Foreground="White"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── NOTES ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10" Margin="0,0,0,285">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Notes"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             x:Name="NotesBox"
                             Foreground="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Padding="8" Margin="0,10,0,25"
                             Background="#FFF3F0D7"
                             Height="NaN"/>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══ BOTTOM BUTTONS ═══ -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTxt"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#FF5555"
                       Visibility="Collapsed"/>

            <Button Grid.Column="1"
                    Content="Save &amp; New"
                    Width="120" Height="32"
                    Margin="0,0,10,0"
                    Click="SaveAndNew_Click"/>

            <Button Grid.Column="2"
                    Content="Save"
                    Width="110" Height="32"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>

            <Button Grid.Column="3"
                    Content="Cancel"
                    Width="110" Height="32"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
