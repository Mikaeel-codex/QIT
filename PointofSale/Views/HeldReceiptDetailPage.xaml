<Page x:Class="PointofSale.Views.HeldReceiptDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White"
      Title="Receipt Detail">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Blue header bar      -->
            <RowDefinition Height="*"/>
            <!-- Items grid+watermark -->
            <RowDefinition Height="Auto"/>
            <!-- Payment button row   -->
            <RowDefinition Height="Auto"/>
            <!-- Reprint button row   -->
            <RowDefinition Height="Auto"/>
            <!-- Totals footer        -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             ROW 0 — Blue header bar
        ══════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#4A6FA5"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Date  " Foreground="#CCDAEE"
                               FontSize="15" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DateTxt"
                               Foreground="White" FontSize="15"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="CashierTxt"
                               Foreground="White" FontSize="13"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CustomerTxt"
                               Foreground="#CCDAEE" FontSize="13"
                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             ROW 1 — Items DataGrid + "Held" watermark
        ══════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <DataGrid x:Name="ItemsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#E8EFF8"
                      AlternationCount="2"
                      Foreground="#222222"
                      FontSize="14"
                      RowHeight="38"
                      SelectionMode="Single">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#C8D4E8"/>
                        <Setter Property="Foreground"      Value="#111111"/>
                        <Setter Property="FontWeight"      Value="Bold"/>
                        <Setter Property="Padding"         Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush"     Value="#BBBBCC"/>
                        <Setter Property="FontSize"        Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#E8EFF8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#B8CCEA"/>
                                <Setter Property="Foreground"  Value="#111111"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item #"
                        Binding="{Binding SKU}"       Width="80"/>
                    <DataGridTextColumn Header="Item Name"
                        Binding="{Binding Name}"      Width="*"/>
                    <DataGridTextColumn Header="Attribute"
                        Binding="{Binding Attribute}" Width="85"/>
                    <DataGridTextColumn Header="Size"
                        Binding="{Binding Size}"      Width="70"/>
                    <DataGridTextColumn Header="Qty"
                        Binding="{Binding Qty}"       Width="50"/>
                    <DataGridTextColumn Header="Price"
                        Binding="{Binding UnitPrice, StringFormat=N2}" Width="80"/>
                    <DataGridTextColumn Header="Ext Price"
                        Binding="{Binding LineTotal, StringFormat=N2}" Width="85"/>
                    <DataGridTextColumn Header="Tax"
                        Binding="{Binding TaxCode}"   Width="65"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- watermark — "Held" normally, "Pending EFT" for pending EFT receipts -->
            <TextBlock x:Name="WatermarkText"
                       Text="Held"
                       FontSize="96" FontWeight="Bold"
                       Foreground="#BBBBBB" Opacity="0.22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-28"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>

        <!-- ══════════════════════════════════════════
             ROW 2 — Payment method indicator
        ══════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#F0F0F0"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PaymentBtn"
                        Content="None"
                        Height="32" MinWidth="110" Padding="16,0"
                        BorderBrush="#AAAAAA" BorderThickness="1"
                        FontSize="13" IsEnabled="False"
                        Cursor="Arrow"
                        TextElement.Foreground="#111111">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"  Value="#E0E0E0"/>
                            <Setter Property="Foreground"  Value="#111111"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="#111111"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background"  Value="#E0E0E0"/>
                                    <Setter Property="Foreground"  Value="#111111"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Pending EFT badge — only visible when status is PendingEFT -->
                <Border x:Name="PendingEftBadge"
                        Visibility="Collapsed"
                        Background="#FF8C00"
                        CornerRadius="4"
                        Padding="10,4"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳  Pending EFT"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             ROW 3 — Reprint button
        ══════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#F8F8F8"
                BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Button Content="Reprint"
                        HorizontalAlignment="Right"
                        Height="34" MinWidth="120" Padding="16,0"
                        Background="#4A6FA5" Foreground="White"
                        BorderBrush="#3A5F95" BorderThickness="1"
                        FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="Reprint_Click"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             ROW 4 — Totals footer
        ══════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="#F8F8F8"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Subtotal"
                           HorizontalAlignment="Right" Margin="0,0,14,0"
                           Foreground="#111111" FontSize="13"/>
                <TextBlock x:Name="SubtotalTxt"
                           Grid.Row="0" Grid.Column="1"
                           HorizontalAlignment="Right"
                           Foreground="#111111" FontSize="13"/>

                <TextBlock Grid.Row="1" Text="Tax"
                           HorizontalAlignment="Right" Margin="0,5,14,0"
                           Foreground="#111111" FontSize="13"/>
                <TextBlock x:Name="TaxTxt"
                           Grid.Row="1" Grid.Column="1"
                           HorizontalAlignment="Right" Margin="0,5,0,0"
                           Foreground="#111111" FontSize="13"/>

                <TextBlock Grid.Row="2" Text="Shipping"
                           HorizontalAlignment="Right" Margin="0,5,14,0"
                           Foreground="#111111" FontSize="13"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="$0.00"
                           HorizontalAlignment="Right" Margin="0,5,0,0"
                           Foreground="#111111" FontSize="13"/>

                <Separator Grid.Row="3" Grid.ColumnSpan="2"
                           Background="#CCCCCC" Margin="0,4"/>

                <TextBlock Grid.Row="4" Text="Total"
                           HorizontalAlignment="Right" Margin="0,0,14,0"
                           FontWeight="Bold" FontSize="20"
                           Foreground="#111111"/>
                <TextBlock x:Name="TotalTxt"
                           Grid.Row="4" Grid.Column="1"
                           HorizontalAlignment="Right"
                           FontWeight="Bold" FontSize="20"
                           Foreground="#111111"/>
            </Grid>
        </Border>
    </Grid>
</Page>
