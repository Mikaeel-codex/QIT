<Window x:Class="PointofSale.Views.CashPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash"
        Height="290" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="MinWidth"        Value="58"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6,0"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Width"           Value="100"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" Padding="16" Margin="0,0,0,-26">
        <StackPanel Margin="0,0,0,-6">

            <TextBlock Text="Cash" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,12"/>

            <Grid x:Name="SummaryGrid" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Sale Total"
                           Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                <TextBlock x:Name="TotalTxt" Grid.Row="0" Grid.Column="1"
                           HorizontalAlignment="Right"
                           Foreground="White" FontSize="12"/>

                <TextBlock x:Name="AlreadyPaidLbl" Grid.Row="1" Text="Already Paid"
                           Foreground="{StaticResource MutedBrush}" FontSize="12" Visibility="Collapsed"/>
                <TextBlock x:Name="AlreadyPaidTxt" Grid.Row="1" Grid.Column="1"
                           HorizontalAlignment="Right"
                           Foreground="#88CC66" FontSize="12" Visibility="Collapsed"/>

                <TextBlock Grid.Row="2" Text="Still Owing"
                           Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold"/>
                <TextBlock x:Name="OwingTxt" Grid.Row="2" Grid.Column="1"
                           HorizontalAlignment="Right"
                           Foreground="#FF8C00" FontSize="12" FontWeight="Bold"/>
            </Grid>

            <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Amount" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                <TextBox x:Name="AmountBox"
                         Grid.Column="1"
                         Height="32"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         FontSize="15"
                         FontWeight="SemiBold"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Button Content="Next Rand" Style="{StaticResource QuickBtn}" Click="NextRand_Click" MinWidth="80" Margin="212,0,0,0" Width="105"/>
                <Button Content="Exact Amount" Style="{StaticResource QuickBtn}" Click="Exact_Click" MinWidth="90" Width="110" Margin="4,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save"   Style="{StaticResource ActionBtn}" Margin="0,0,8,0" Click="Save_Click"/>
                <Button Content="Cancel" Style="{StaticResource ActionBtn}"
                        Background="{StaticResource Panel2Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
