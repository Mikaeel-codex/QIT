<Window x:Class="PointofSale.Views.CashPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash"
        Height="254" Width="602"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#000000"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Background"      Value="#181818"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="MinWidth"        Value="58"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6,0"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2F66C8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#1F4E9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Width"           Value="100"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#000000" Padding="20">
        <StackPanel Margin="0,0,-6,0">

            <!-- Title -->
            <TextBlock Text="Cash" FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="0,0,0,12"/>

            <!-- Amount row -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Amount" VerticalAlignment="Center"
                           Foreground="#BBBBBB" FontSize="13"/>
                <TextBox x:Name="AmountBox"
                         Grid.Column="1"
                         Height="32"
                         HorizontalContentAlignment="Right"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         Background="#0E0E0E"
                         Foreground="White"
                         BorderBrush="#333333"
                         BorderThickness="1"
                         FontSize="15"
                         FontWeight="SemiBold"
                         CaretBrush="White"
                         SelectionBrush="#2F66C8" Margin="0,0,55,0"/>
            </Grid>

            <!-- Quick-amount buttons -->
            <StackPanel Orientation="Horizontal" Margin="17,0,0,14" Width="443">
                <Button Content="R1"            Style="{StaticResource QuickBtn}" Margin="6,0,6,0" Click="Quick_Click" Tag="1" Width="60"/>
                <Button Content="R5"            Style="{StaticResource QuickBtn}" Margin="6,0,6,0" Click="Quick_Click" Tag="5" Width="60"/>
                <Button Content="R10"           Style="{StaticResource QuickBtn}" Margin="6,0,6,0" Click="Quick_Click" Tag="10" Width="60"/>
                <Button Content="R20"           Style="{StaticResource QuickBtn}" Click="Quick_Click" Tag="20" Width="60" Margin="6,0,0,0"/>
                <Button Content="Exact Amount"  Style="{StaticResource QuickBtn}" Click="Exact_Click" MinWidth="90" Width="140" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="5,0,5,0" Margin="20,0,5,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Width="242" RenderTransformOrigin="0.494,0.464" HorizontalAlignment="Center" Margin="212,0,0,0">
                <Button Content="Save"   Style="{StaticResource ActionBtn}" Click="Save_Click" Width="100" Margin="20,0,20,0"/>
                <Button Content="Cancel" Style="{StaticResource ActionBtn}"
                        Background="#444" BorderBrush="#555" Click="Cancel_Click" Margin="0,0,50,0"/>
            </StackPanel>

            <!-- Save / Cancel -->

        </StackPanel>
    </Border>
</Window>
