<Window x:Class="PointofSale.Views.SupplierEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Supplier"
        Width="940" Height="945"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP: SUPPLIER INFO -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="12"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Supplier Info"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                </DockPanel>

                <!-- Company Name -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Company Name"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12"/>
                    <ComboBox x:Name="CompanyNameBox"
                              Grid.Column="1"
                              Height="28"
                              IsEditable="True"
                              Padding="6,2"/>
                    <TextBlock Grid.Column="2"
                               Text="*"
                               Foreground="Red"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </Grid>

                <!-- Supplier Code -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Supplier Code"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="12"/>
                    <TextBox x:Name="SupplierCodeBox"
                             Grid.Column="1"
                             Height="28"
                             Padding="6,2"/>
                </Grid>
            </Grid>
        </Border>

        <!-- MIDDLE: 4 BLOCKS + NOTES + HISTORY -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CONTACT INFO -->
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,10,10"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Contact Info" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Title" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TitleBox"
                                  Height="26" Padding="6,1"
                                  SelectionChanged="TitleBox_SelectionChanged">
                            <ComboBoxItem Content=""/>
                            <ComboBoxItem Content="Mr"/>
                            <ComboBoxItem Content="Mrs"/>
                            <ComboBoxItem Content="Ms"/>
                            <ComboBoxItem Content="Dr"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Text="First Name" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FirstNameBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Text="Last Name" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="LastNameBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="3" Text="Phone" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="PhoneBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="4" Text="Email" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="EmailBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="5" Text="Website" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="WebsiteBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="6" Text="Street" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="StreetBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="7" Text="Street 2" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="7" Grid.Column="1" x:Name="Street2Box" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="8" Text="City" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="8" Grid.Column="1" x:Name="CityBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="9" Text="State / Province" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="9" Grid.Column="1" x:Name="StateBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="10" Text="Zip / Postal" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="10" Grid.Column="1" x:Name="ZipBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="11" Text="Country" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox Grid.Row="11" Grid.Column="1" x:Name="CountryBox" Height="26" Padding="6,1" Margin="0,8,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- SUPPLIER SETTINGS -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="5,0,5,231"
                    Padding="10" Grid.RowSpan="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Supplier Settings" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Account #" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="AccountBox" Height="26" Padding="6,1"/>

                        <TextBlock Grid.Row="1" Text="Alt. Phone" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="AltPhoneBox" Height="26" Padding="6,1" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="2" Text="Alt. Contact" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="AltContactBox" Height="26" Padding="6,1" Margin="0,10,0,0"/>

                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="InactiveCheck"
                                  Content="Inactive"
                                  Margin="0,12,0,0"
                                  Foreground="White"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- SUPPLIER NOTES -->
            <Border Grid.Column="2" Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="24,0,24,10"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Supplier Notes" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             x:Name="NotesBox"
                             Height="170"
                             Width="220"
                             Foreground="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8" Background="#FFF3F0D7"/>
                </Grid>
            </Border>

            <!-- HISTORY -->
            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,10,17"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="History" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="▾" Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             x:Name="HistoryList"
                             BorderBrush="{StaticResource BorderBrush}"
                             Background="{StaticResource Panel2Brush}"
                             Foreground="White"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Background="Transparent"/>
        </Grid>

        <!-- BOTTOM BUTTONS -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Save &amp; New"
                    Width="120" Height="32"
                    HorizontalAlignment="Left"
                    Margin="0,0,10,0"
                    Click="SaveAndNew_Click"/>

            <Button Grid.Column="1"
                    Content="Save"
                    Width="110" Height="32"
                    Margin="0,0,10,0"
                    Click="Save_Click"/>

            <Button Grid.Column="2"
                    Content="Cancel"
                    Width="110" Height="32"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
