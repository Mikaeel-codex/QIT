<Window x:Class="PointofSale.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Inventory Till — Sign In"
        Width="632" Height="456"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>

        <!-- Floating label TextBox style -->
        <Style x:Key="FloatLabelBox" TargetType="TextBox">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0,0,0,1"/>
            <Setter Property="BorderBrush"          Value="#B0BFCC"/>
            <Setter Property="Foreground"           Value="#2B3A52"/>
            <Setter Property="FontSize"             Value="14"/>
            <Setter Property="FontWeight"           Value="Medium"/>
            <Setter Property="Padding"              Value="4,10,4,6"/>
            <Setter Property="CaretBrush"           Value="#5E7EB6"/>
            <Setter Property="SelectionBrush"       Value="#5E7EB6"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Bottom"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#5E7EB6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Floating label PasswordBox style -->
        <Style x:Key="FloatLabelPass" TargetType="PasswordBox">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0,0,0,1"/>
            <Setter Property="BorderBrush"          Value="#B0BFCC"/>
            <Setter Property="Foreground"           Value="#2B3A52"/>
            <Setter Property="FontSize"             Value="14"/>
            <Setter Property="FontWeight"           Value="Medium"/>
            <Setter Property="Padding"              Value="4,10,4,6"/>
            <Setter Property="CaretBrush"           Value="#5E7EB6"/>
            <Setter Property="SelectionBrush"       Value="#5E7EB6"/>
            <Setter Property="VerticalContentAlignment" Value="Bottom"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Bottom"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#5E7EB6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Submit button -->
        <Style x:Key="SubmitBtn" TargetType="Button">
            <Setter Property="Background"      Value="#5E7EB6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A6AA0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A5A8F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0.003"/>
            <GradientStop Color="White"/>
            <GradientStop Color="#FF1D3563" Offset="0.893"/>
            <GradientStop Color="#FFF8F8F8"/>
        </LinearGradientBrush>
    </Window.Background>

    <!-- Outer container — glassmorphism card -->
    <Border CornerRadius="15"
            Background="#28FFFFFF"
            MouseDown="TitleBar_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18"
                              BlurRadius="30" ShadowDepth="8"
                              Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left — form (66%) -->
                <ColumnDefinition Width="2.2*"/>
                <!-- Right — illustration (34%) -->
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ── RIGHT — decorative gradient circle + illustration ── -->
            <Border Grid.Column="1" CornerRadius="0,15,15,0" ClipToBounds="True">
                <Grid>
                    <!-- Soft radial background -->
                    <Ellipse Width="232" Height="215"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,124,-34,0">
                        <Ellipse.Fill>
                            <ImageBrush Stretch="None" Opacity="0.7" TileMode="None" ImageSource="/Views/QIT Logo.png"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Illustration placeholder — gold Q badge -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- ── LEFT — form panel ── -->
            <Border Grid.Column="0"
                    CornerRadius="15,0,0,15"
                    ClipToBounds="True">

                <!-- Blur glow blob behind the form -->
                <Grid>

                    <!-- Form content -->
                    <StackPanel VerticalAlignment="Center"
                                Margin="40,0,30,0">

                        <!-- App name / heading -->
                        <TextBlock Text="Sign In"
                                   Foreground="White"
                                   FontSize="24" FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Welcome back to Quick Inventory Till"
                                   Foreground="White"
                                   FontSize="11"
                                   Margin="0,0,0,28"/>

                        <!-- Username field -->
                        <Grid Margin="0,0,0,20">
                            <TextBox x:Name="UsernameBox"
                                     Style="{StaticResource FloatLabelBox}"
                                     KeyDown="Field_KeyDown"
                                     GotFocus="Field_GotFocus"
                                     LostFocus="Field_LostFocus" Foreground="White"/>
                            <TextBlock x:Name="UsernameLbl"
                                       Text="Username"
                                       Foreground="White"
                                       FontSize="13"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,0,8"
                                       RenderTransformOrigin="0,1">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="UsernameLblScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="UsernameLblTranslate" Y="0"/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>

                        <!-- Password field -->
                        <Grid Margin="0,0,0,8">
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{StaticResource FloatLabelPass}"
                                         KeyDown="Field_KeyDown"
                                         GotFocus="PassField_GotFocus"
                                         LostFocus="PassField_LostFocus" Foreground="White"/>
                            <TextBlock x:Name="PasswordLbl"
                                       Text="Password"
                                       Foreground="White"
                                       FontSize="13"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,0,8"
                                       RenderTransformOrigin="0,1">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="PasswordLblScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="PasswordLblTranslate" Y="0"/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>

                        <!-- Error message -->
                        <TextBlock x:Name="ErrorTxt"
                                   Foreground="#D9534F"
                                   FontSize="11"
                                   Margin="4,0,0,8"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"/>

                        <!-- Forgot password -->
                        <TextBlock Margin="0,0,0,18">
                            <Hyperlink x:Name="ForgotLink"
                                       Foreground="#5E7EB6"
                                       TextDecorations="None"
                                       Click="ForgotLink_Click">
                                Forgot Password?
                            </Hyperlink>
                        </TextBlock>

                        <!-- Submit button -->
                        <Button x:Name="LoginBtn"
                                Content="Sign In"
                                Style="{StaticResource SubmitBtn}"
                                Click="LoginBtn_Click"/>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Close button -->
            <Button Grid.Column="1"
                    Content="✕"
                    Width="28" Height="28"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="13"
                    Cursor="Hand"
                    Click="CloseBtn_Click"/>

        </Grid>
    </Border>
</Window>
