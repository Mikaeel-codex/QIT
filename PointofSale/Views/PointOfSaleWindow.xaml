<Window x:Class="PointofSale.Views.PointOfSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Receipt"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="White"
        TextElement.Foreground="White">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush"  Color="#2F66C8"/>
        <SolidColorBrush x:Key="RowAltBrush"  Color="#0F0F0F"/>
        <SolidColorBrush x:Key="RowBrush"     Color="#181818"/>

        <Style x:Key="PayButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="38"/>
        </Style>

        <Style x:Key="FooterButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="12,0"/>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource FooterButton}">
            <Setter Property="Background"  Value="#3A7D44"/>
            <Setter Property="BorderBrush" Value="#2D6035"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="BorderBrush"     Value="#1F4E9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="MinWidth"        Value="70"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource RowBrush}"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource RowAltBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#274A8A"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DropdownRowStyle" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Padding"     Value="6,5"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid PreviewKeyDown="Grid_PreviewKeyDown"
          Loaded="MainWindow_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0 — TOOLBAR ═══ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- PRODUCT SEARCH -->
                <Grid Grid.Column="0">
                    <!-- Scan box with placeholder + dropdown arrow -->
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="2"
                                Background="#0E0E0E"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"/>
                        <TextBox x:Name="ScanBoxTop"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 FontSize="13"
                                 Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="ScanBox_KeyDown"
                                 TextChanged="ScanBox_TextChanged"
                                 LostFocus="ScanBox_LostFocus"
                                 Panel.ZIndex="1"/>
                        <!-- Placeholder -->
                        <TextBlock Grid.Column="0"
                                   Text="Scan or enter item information  (Name / SKU / ALU)"
                                   Foreground="#555555"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Panel.ZIndex="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ScanBoxTop}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Dropdown arrow button -->
                        <Button Grid.Column="1"
                                Background="{StaticResource GoldBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ScanDropdownArrow_Click"
                                ToolTip="Browse products">
                            <TextBlock Text="▼" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Popup x:Name="ProductPopup"
                           PlacementTarget="{Binding ElementName=ScanBoxTop}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource GoldBrush}"
                                BorderThickness="1"
                                Width="730"
                                MaxHeight="340">
                            <Grid Grid.IsSharedSizeScope="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header row using SharedSizeGroup -->
                                <Grid Grid.Row="0" Background="{StaticResource Panel2Brush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Item Name"  Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6"/>
                                    <TextBlock Grid.Column="1" Text="SKU"        Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6"/>
                                    <TextBlock Grid.Column="2" Text="ALU"        Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6"/>
                                    <TextBlock Grid.Column="3" Text="Attribute"  Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6"/>
                                    <TextBlock Grid.Column="4" Text="Size"       Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6"/>
                                    <TextBlock Grid.Column="5" Text="Price"      Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,6" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Results list -->
                                <ListBox x:Name="ProductList"
                                         Grid.Row="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         MouseDoubleClick="ProductList_MouseDoubleClick"
                                         KeyDown="ProductList_KeyDown">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding"     Value="0"/>
                                            <Setter Property="Margin"      Value="0"/>
                                            <Setter Property="Foreground"  Value="White"/>
                                            <Setter Property="Cursor"      Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#274A8A"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#2F66C8"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#2A2A3E" BorderThickness="0,0,0,1" Padding="0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="220"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="8,4">
                                                        <TextBlock Text="{Binding Name}"        FontWeight="SemiBold" FontSize="12"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="#AAAAAA"  FontSize="10" FontStyle="Italic"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SKU}"        Padding="8,0" VerticalAlignment="Center" FontSize="12"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ALU}"        Padding="8,0" VerticalAlignment="Center" FontSize="12"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Department}" Padding="8,0" VerticalAlignment="Center" FontSize="12"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding Size}"       Padding="8,0" VerticalAlignment="Center" FontSize="12"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding Price, StringFormat=C}" Padding="8,0" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>

                <!-- CUSTOMER SEARCH -->
                <Grid Grid.Column="2">
                    <!-- Customer box with placeholder + dropdown arrow -->
                    <Grid Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.ColumnSpan="2"
                                Background="#0E0E0E"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"/>
                        <TextBox x:Name="CustomerBoxTop"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 FontSize="13"
                                 Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="CustomerBox_KeyDown"
                                 TextChanged="CustomerBox_TextChanged"
                                 LostFocus="CustomerBox_LostFocus"
                                 Panel.ZIndex="1"/>
                        <!-- Placeholder -->
                        <TextBlock Grid.Column="0"
                                   Text="Enter customer name or phone"
                                   Foreground="#555555"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Panel.ZIndex="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=CustomerBoxTop}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Dropdown arrow button -->
                        <Button Grid.Column="1"
                                Background="#2F66C8"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="CustomerDropdownArrow_Click"
                                ToolTip="Browse customers">
                            <TextBlock Text="▼" Foreground="White" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Popup x:Name="CustomerPopup"
                           PlacementTarget="{Binding ElementName=CustomerBoxTop}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="#1C1C2E"
                                BorderBrush="#2F66C8"
                                BorderThickness="1"
                                MinWidth="{Binding ActualWidth, ElementName=CustomerBoxTop}"
                                MaxHeight="280">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Background="#222831">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Last Name"  Foreground="White" FontWeight="Bold" FontSize="11" Padding="8,5"/>
                                    <TextBlock Grid.Column="1" Text="First Name" Foreground="White" FontWeight="Bold" FontSize="11" Padding="4,5"/>
                                    <TextBlock Grid.Column="2" Text="Phone"      Foreground="White" FontWeight="Bold" FontSize="11" Padding="4,5"/>
                                </Grid>
                                <ListBox x:Name="CustomerList"
                                         Grid.Row="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource DropdownRowStyle}"
                                         MouseDoubleClick="CustomerList_MouseDoubleClick"
                                         KeyDown="CustomerList_KeyDown">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="140"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding LastName}"  VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FirstName}" VerticalAlignment="Center" FontSize="12"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Phone}"     VerticalAlignment="Center" FontSize="12"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>

                <!-- User label + Home -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabelTop"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="0,0,10,0"/>
                    <Button Content="Home"
                            Style="{StaticResource ModernButton}"
                            Height="28"
                            Click="HomeBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 1 — RECEIPT DATAGRID ═══ -->
        <DataGrid Grid.Row="1"
                  x:Name="ReceiptGrid"
                  CellEditEnding="ReceiptGrid_CellEditEnding"
                  ItemsSource="{Binding Cart}"
                  AlternationCount="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowDetailsVisibilityMode="VisibleWhenSelected"
                  FontSize="13"
                  Background="#111111"
                  RowBackground="{StaticResource RowBrush}"
                  AlternatingRowBackground="{StaticResource RowAltBrush}"
                  Foreground="White"
                  HorizontalGridLinesBrush="#222222"
                  RowHeight="32"
                  EnableRowVirtualization="True" SelectionChanged="ReceiptGrid_SelectionChanged">

            <!-- Row height auto-expands when discount line is shown via StackPanel -->

            <!-- Remove default cell padding so editing controls fill without clipping -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding"             Value="0"/>
                    <Setter Property="BorderThickness"     Value="0"/>
                    <Setter Property="VerticalAlignment"   Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="0"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#274A8A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsEditing" Value="True">
                                        <Setter Property="Background" Value="#1A2535"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>

                <!-- Item # — READ ONLY, no editing -->
                <DataGridTextColumn Header="Item #"
                                    Binding="{Binding ProductId}"
                                    Width="110"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"       Value="#AAAAAA"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding"          Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Item Name — editable TextBox -->
                <DataGridTemplateColumn Header="Item Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           Foreground="White" FontSize="13"/>
                                <TextBlock Grid.Column="1"
                                           Visibility="{Binding DiscountVisibility}"
                                           VerticalAlignment="Center"
                                           Foreground="#88CC66" FontSize="11"
                                           Margin="8,0,0,0">
                                    <Run Text="Discount %: "/>
                                    <Run Text="{Binding DiscountPct, StringFormat=N2}" FontWeight="SemiBold"/>
                                    <Run Text="   Original Price: "/>
                                    <Run Text="{Binding OriginalPrice, StringFormat=N2}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2A3A" Foreground="White"
                                     BorderBrush="#2F66C8" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center"
                                     Height="28"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Attribute — editable TextBox -->
                <DataGridTemplateColumn Header="Attribute" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Attribute}" VerticalAlignment="Center" Padding="4,0" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Attribute, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2A3A" Foreground="White"
                                     BorderBrush="#2F66C8" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center"
                                     Height="28"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Size — editable TextBox -->
                <DataGridTemplateColumn Header="Size" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Size}" VerticalAlignment="Center" Padding="4,0" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2A3A" Foreground="White"
                                     BorderBrush="#2F66C8" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center"
                                     Height="28"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Qty — editable TextBox (numeric) -->
                <DataGridTemplateColumn Header="Qty" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Qty}" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2A3A" Foreground="White"
                                     BorderBrush="#2F66C8" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center"
                                     Height="28"
                                     PreviewTextInput="NumericOnly_PreviewTextInput"
                                     PreviewKeyDown="QtyTextBox_PreviewKeyDown"
                                     LostFocus="QtyTextBox_LostFocus"
                                     Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Price — editable TextBox (numeric) -->
                <DataGridTemplateColumn Header="Price" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UnitPrice, StringFormat=N2}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Padding="0,0,6,0" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2A3A" Foreground="White"
                                     BorderBrush="#2F66C8" BorderThickness="1"
                                     Padding="4,2" VerticalContentAlignment="Center"
                                     Height="28"
                                     PreviewTextInput="DecimalOnly_PreviewTextInput"
                                     PreviewKeyDown="PriceTextBox_PreviewKeyDown"
                                     LostFocus="PriceTextBox_LostFocus"
                                     Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Ext Price — READ ONLY (computed) -->
                <DataGridTextColumn Header="Ext Price"
                                    Binding="{Binding LineTotal, StringFormat=N2}"
                                    Width="95"
                                    IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Padding"             Value="0,0,6,0"/>
                            <Setter Property="Foreground"          Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Tax Code — editable ComboBox -->
                <DataGridTemplateColumn Header="Tax Code" Width="95">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TaxCode}" VerticalAlignment="Center" Padding="4,0" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding TaxCode, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding DataContext.TaxCodeOptions,
                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      Background="#1E2A3A" Foreground="White"
                                      BorderBrush="#2F66C8" BorderThickness="1"
                                      Height="28"
                                      SelectionChanged="TaxCodeCombo_SelectionChanged"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <StackPanel>
                        <!-- Action buttons — always shown -->
                        <Border Background="#183B72" Padding="8,6" BorderBrush="#142C57" BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Edit"               Height="24" MinWidth="70"  Margin="0,0,6,0" Background="#2F66C8" Foreground="White" BorderBrush="#1F4E9A" BorderThickness="1" Click="EditLine_Click"/>
                                <Button Content="Return Item"        Height="24" MinWidth="90"  Margin="0,0,6,0" Background="#2F66C8" Foreground="White" BorderBrush="#1F4E9A" BorderThickness="1" Click="ReturnLine_Click"/>
                                <Button Content="Qty/Price/Discount" Height="24" MinWidth="140" Margin="0,0,6,0" Background="#2F66C8" Foreground="White" BorderBrush="#1F4E9A" BorderThickness="1" Click="QtyPriceDiscount_Click"/>
                                <Button Content="Qty +"              Height="24" MinWidth="60"  Margin="0,0,6,0" Background="#2F66C8" Foreground="White" BorderBrush="#1F4E9A" BorderThickness="1"
                                        Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Qty -"              Height="24" MinWidth="60"  Margin="0,0,6,0" Background="#2F66C8" Foreground="White" BorderBrush="#1F4E9A" BorderThickness="1"
                                        Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="Remove"             Height="24" MinWidth="80"  Background="#D9534F" Foreground="White" BorderBrush="#B54541" BorderThickness="1"
                                        Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <!-- ═══ ROW 2 — BOTTOM BAR ═══ -->
        <Border Grid.Row="2"
                Background="#111111"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0">
            <StackPanel Orientation="Vertical">

                <!-- TOP ROW: Date (left) + Totals (right) -->
                <Grid Margin="8,6,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Date -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <TextBlock Text="Date" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="6,2">
                            <TextBlock Text="{Binding SaleDate, StringFormat=MM/dd/yyyy}"
                                       Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <!-- Totals grid (right-aligned) -->
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="No. of Items Sold" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ItemsSold}" HorizontalAlignment="Right" Foreground="White" FontSize="12"/>

                        <TextBlock Grid.Row="1" Text="Total Qty Sold" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalQtySold}" HorizontalAlignment="Right" Foreground="White" FontSize="12"/>

                        <TextBlock Grid.Row="2" Text="SubTotal" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Subtotal, StringFormat=N2}" HorizontalAlignment="Right" Foreground="White" FontSize="12"/>

                        <TextBlock Grid.Row="3" Text="Tax" HorizontalAlignment="Right" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Tax, StringFormat=N2}" HorizontalAlignment="Right" Foreground="White" FontSize="12"/>

                        <TextBlock Grid.Row="4" Text="Total" HorizontalAlignment="Right" Foreground="White" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Total, StringFormat=N2}" HorizontalAlignment="Right" Foreground="White" FontSize="15" FontWeight="Bold"/>

                        <!-- Dynamic split rows — one per payment method, shown as negative deductions -->
                        <ItemsControl Grid.Row="5" Grid.ColumnSpan="2"
                                      ItemsSource="{Binding Splits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Label: e.g. "Cash" or "Gift Card #2232" -->
                                        <TextBlock Text="{Binding Label}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="#BBBBBB"
                                                   FontSize="12"/>
                                        <!-- Amount shown as negative -->
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   Foreground="White"
                                                   FontSize="12">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="-{0:N2}">
                                                    <Binding Path="Amount"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Grid.Row="6" Grid.ColumnSpan="2" Background="#2B2B2B" Margin="0,4,0,4"/>

                        <!-- Amount Due: red when > 0, white when 0 -->
                        <TextBlock Grid.Row="7" Text="Amount Due" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E53935"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AmountDueIsZero}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding AmountDue, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E53935"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AmountDueIsZero}" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Cash Change: only visible when change > 0 -->
                        <TextBlock Grid.Row="8" Text="Cash Change" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15" Foreground="White"
                                   Visibility="{Binding CashChangeVisibility}"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CashChange, StringFormat=N2}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15" Foreground="White"
                                   Visibility="{Binding CashChangeVisibility}"/>
                    </Grid>
                </Grid>

                <!-- DIVIDER -->
                <Separator Background="#2B2B2B" Margin="0,0,0,0"/>

                <!-- BOTTOM ROW: Payment buttons (left) + Amount Due / Cash Change + Footer buttons (right) -->
                <Grid Margin="8,6,8,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Payment buttons -->
                        <ColumnDefinition Width="*"/>
                        <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Footer buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Payment section: status card + buttons -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">

                        <!-- Payment status card — QB style -->
                        <Border x:Name="PaymentCardBorder"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Padding="10,6"
                                Margin="0,0,0,6"
                                MinWidth="360">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: payment method name -->
                                <TextBlock x:Name="PaymentStatusTxt"
                                           Text="No payment selected"
                                           Foreground="#888888" FontSize="13"
                                           VerticalAlignment="Center"
                                           FontStyle="Italic"/>

                                <!-- Right: amount confirmed / change -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PaymentAmountTxt"
                                               Foreground="#4CAF50" FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Visibility="Collapsed"/>
                                    <TextBlock x:Name="PaymentChangeTxt"
                                               Foreground="#AAAAAA" FontSize="11"
                                               HorizontalAlignment="Right"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Payment buttons row -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnCash"    Content="Cash"    Width="100" Margin="0,0,6,0" Style="{StaticResource PayButton}" Click="Cash_Click"/>
                            <Button x:Name="BtnCredit"  Content="Credit"  Width="100" Margin="0,0,6,0" Style="{StaticResource PayButton}" Click="Credit_Click"/>
                            <Button x:Name="BtnEft"     Content="EFT"     Width="100" Margin="0,0,6,0" Style="{StaticResource PayButton}" Click="Eft_Click"/>
                            <Button x:Name="BtnGift"    Content="Gift"    Width="100" Margin="0,0,6,0" Style="{StaticResource PayButton}" Click="Gift_Click"/>
                            <Button x:Name="BtnAccount" Content="Account" Width="100"                  Style="{StaticResource PayButton}" Click="Account_Click"/>
                            <Button Content="Remove Payment" Width="130" Margin="16,0,0,0"
                                    Background="#8B0000" BorderBrush="#600000" BorderThickness="1"
                                    Foreground="White" FontWeight="SemiBold" FontSize="13"
                                    Height="38" Cursor="Hand"
                                    Click="RemovePayment_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer action buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="HoldBtn" Content="Put on Hold" Margin="0,0,4,0" Style="{StaticResource FooterButton}" Click="HoldBtn_Click"/>
                        <Button Content="Cancel"           Margin="0,0,4,0" Style="{StaticResource FooterButton}" Click="Cancel_Click"/>
                        <Button Content="Send Receipt"  Margin="0,0,4,0" Style="{StaticResource SaveButton}"   Click="SaveEmail_Click"/>
                        <Button Content="Save Only"        Margin="0,0,4,0" Style="{StaticResource SaveButton}"   Click="SaveOnly_Click"/>
                        <Button Content="Save &amp; Print"                  Style="{StaticResource SaveButton}"   Click="SavePrint_Click"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Border>

        <!-- ═══ LOW STOCK TOAST — floats top-right over everything ═══ -->
        <Border x:Name="LowStockToast"
                Grid.RowSpan="3"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,60,16,0"
                Background="#1A1A00"
                BorderBrush="#FFA500"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,10"
                MaxWidth="340"
                Panel.ZIndex="999">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="⚠  Low Stock Warning"
                               Foreground="#FFA500"
                               FontWeight="Bold"
                               FontSize="12"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="LowStockMsg"
                               Foreground="#FFDD88"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="✕"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#888888"
                        FontSize="13"
                        Cursor="Hand"
                        VerticalAlignment="Top"
                        Margin="10,0,0,0"
                        Click="DismissLowStock_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
