<Window x:Class="PointofSale.Views.PointOfSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Point of Sale"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid Margin="16"
          PreviewKeyDown="Grid_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP NAVBAR -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Brand + Admin buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Point of Sale"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="6,0,14,0"/>

                    <Button x:Name="ProductsBtn"
                            Style="{StaticResource ModernButton}"
                            Content="Products"
                            Margin="0,0,8,0"
                            Click="ProductsBtn_Click"/>

                    <Button x:Name="UsersBtn"
                            Style="{StaticResource ModernButton}"
                            Content="Users"
                            Margin="0,0,8,0"
                            Click="UsersBtn_Click"/>

                    <Button x:Name="ReportsBtn"
                            Style="{StaticResource ModernButton}"
                            Content="Reports"
                            Click="ReportsBtn_Click"/>
                </StackPanel>

                <!-- Right: User info + Logout -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <Button Style="{StaticResource ModernButton}"
                            Content="Logout"
                            Click="LogoutBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN POS LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: PRODUCTS -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Products top bar -->
                <Border CornerRadius="14"
                        Background="{StaticResource PanelBrush}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Products" FontSize="24" FontWeight="SemiBold"/>

                        <TextBox Grid.Column="1"
                                 Margin="16,0,16,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource HintTextBox}"
                                 Tag="Search by name or SKU..."
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBox x:Name="ScanBox"
                                 Width="220"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Style="{StaticResource HintTextBox}"
                                 Tag="Scan barcode..."
                                 KeyDown="ScanBox_KeyDown"/>


                        <Button Grid.Column="2"
                                Style="{StaticResource ModernButton}"
                                Content="Add Product"/>
                    </Grid>
                </Border>

                <!-- Product cards (DB bound) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Height="140" Margin="0,0,12,12"
                                        CornerRadius="16"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="14">

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SKU, StringFormat=SKU: {0}}"
                                                       Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding StockQty, StringFormat=Stock: {0}}"
                                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Grid Grid.Row="1" Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Price, StringFormat=R {0:0.00}}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource GoldBrush}"/>

                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GoldButton}"
                                                    Content="Add"
                                                    Padding="12,6"
                                                    Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- RIGHT: CART -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart header -->
                <Border CornerRadius="14"
                        Background="{StaticResource PanelBrush}"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Cart" FontSize="24" FontWeight="SemiBold"/>

                        <Button Grid.Column="1"
                                Style="{StaticResource ModernButton}"
                                Content="Clear"
                                Command="{Binding ClearCartCommand}" />
                    </Grid>
                </Border>

                <!-- Cart items (DB bound) -->
                <Border Grid.Row="1"
                        CornerRadius="14"
                        Background="{StaticResource PanelBrush}"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Cart}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                            Background="{StaticResource Panel2Brush}"
                                            Padding="12"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0">
                                                    <Run Text="{Binding UnitPrice, StringFormat=R {0:0.00}}"/>
                                                    <Run Text=" x "/>
                                                    <Run Text="{Binding Qty}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource ModernButton}"
                                                        Content="-"
                                                        Width="32" Height="32" Padding="0"
                                                        Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />

                                                <TextBlock Text="{Binding Qty}"
                                                           Width="28"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Style="{StaticResource ModernButton}"
                                                        Content="+"
                                                        Width="32" Height="32" Padding="0"
                                                        Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Totals + Pay -->
                <Border Grid.Row="2"
                        CornerRadius="14"
                        Background="{StaticResource PanelBrush}"
                        Padding="16"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Subtotal" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Subtotal, StringFormat=R {0:0.00}}"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Total" Foreground="{StaticResource MutedBrush}" FontSize="16"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Total, StringFormat=R {0:0.00}}"
                                       Foreground="{StaticResource GoldBrush}"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                        </Grid>

                        <Button Style="{StaticResource GoldButton}"
                                Height="54"
                                FontSize="16"
                                Content="PAY"
                                Command="{Binding PayCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
