<Window x:Class="PointofSale.Views.GiftCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gift Card"
        Width="420" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"         Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin"             Value="0,0,10,0"/>
        </Style>
        <Style x:Key="BlueBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="18,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Radio buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <RadioButton x:Name="RbRedeem"
                         Content="Redeem card"
                         FontSize="13"
                         Foreground="White"
                         IsChecked="True"
                         GroupName="GiftMode"
                         Margin="0,0,20,0"
                         Checked="Mode_Changed"/>
            <RadioButton x:Name="RbPurchase"
                         Content="Purchase / recharge card"
                         FontSize="13"
                         Foreground="White"
                         GroupName="GiftMode"
                         Checked="Mode_Changed"/>
        </StackPanel>

        <!-- Amount row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Amount" Style="{StaticResource LabelStyle}"/>
            <TextBox   Grid.Column="1" x:Name="AmountBox"
                       Height="28" Padding="6,2" FontSize="13"
                       PreviewTextInput="Decimal_PreviewTextInput"/>
        </Grid>

        <!-- Card Number row -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Gift Card Number" Style="{StaticResource LabelStyle}"/>
            <TextBox   Grid.Column="1" x:Name="CardNumberBox"
                       Height="28" Padding="6,2" FontSize="13"
                       ToolTip="Swipe or enter gift card number"
                       TextChanged="CardNumber_TextChanged"/>
        </Grid>

        <!-- Balance info -->
        <Border Grid.Row="6"
                x:Name="BalancePanel"
                Visibility="Collapsed"
                Background="{StaticResource Panel2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6">
            <TextBlock x:Name="BalanceTxt"
                       Foreground="#88CC66"
                       FontSize="12"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"   Style="{StaticResource BlueBtn}" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Style="{StaticResource BlueBtn}"
                    Background="{StaticResource Panel2Brush}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
