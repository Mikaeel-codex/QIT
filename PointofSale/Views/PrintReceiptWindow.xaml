<Window x:Class="PointofSale.Views.PrintReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Receipt"
        Width="380" Height="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <StackPanel Margin="24,20,24,20">

        <TextBlock Text="🖨  Print Receipt"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="ReceiptNumberTxt"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12" Margin="0,0,0,20"/>

        <!-- Options -->
        <RadioButton x:Name="PrintNowRadio"
                     Content="Print receipt now"
                     Foreground="White" FontSize="13"
                     IsChecked="True"
                     Margin="0,0,0,10"
                     GroupName="PrintOption"/>

        <RadioButton x:Name="PreviewRadio"
                     Content="Preview receipt before printing"
                     Foreground="White" FontSize="13"
                     Margin="0,0,0,10"
                     GroupName="PrintOption"/>

        <RadioButton x:Name="SendDigitalRadio"
                     Content="Send via Email / WhatsApp"
                     Foreground="#88CCFF" FontSize="13"
                     Margin="0,0,0,24"
                     Visibility="Collapsed"
                     GroupName="PrintOption"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Continue"
                    Width="110" Height="32"
                    Margin="0,0,10,0"
                    Background="#3A7D44" Foreground="White"
                    BorderBrush="#2D6035" BorderThickness="1"
                    FontWeight="SemiBold" Cursor="Hand"
                    Click="ContinueBtn_Click"/>
            <Button Content="Cancel"
                    Width="80" Height="32"
                    Background="{StaticResource Panel2Brush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Foreground="White" Cursor="Hand"
                    Click="CancelBtn_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
