<Window x:Class="PointofSale.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory - Item List"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Item List" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Add, edit, and manage stock"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         Margin="12,0,12,0"
                         VerticalContentAlignment="Center"
                         Style="{StaticResource HintTextBox}"
                         Tag="Search inventory..."
                         TextChanged="SearchBox_TextChanged"/>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ModernButton}" Content="Refresh" Margin="0,0,8,0" Click="RefreshBtn_Click"/>
                    <Button x:Name="AddBtn"    Style="{StaticResource ModernButton}" Content="Add"     Margin="0,0,8,0" Click="AddBtn_Click"/>
                    <Button x:Name="EditBtn"   Style="{StaticResource ModernButton}" Content="Edit"    Margin="0,0,8,0" Click="EditBtn_Click"/>
                    <Button x:Name="DeleteBtn" Style="{StaticResource ModernButton}" Content="Delete"  Click="DeleteBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ProductsGrid"
                          Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="{StaticResource PanelBrush}"
                          Foreground="White"
                          RowBackground="{StaticResource PanelBrush}"
                          AlternatingRowBackground="{StaticResource Panel2Brush}"
                          BorderThickness="0"
                          SelectionMode="Single"
                          ColumnHeaderHeight="34"
                          RowHeight="34"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          HorizontalScrollBarVisibility="Hidden"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True"
                          SelectionChanged="ProductsGrid_SelectionChanged"
                          MouseDoubleClick="ProductsGrid_MouseDoubleClick">

                    <DataGrid.Resources>

                        <!-- Header -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground"                Value="White"/>
                            <Setter Property="Background"                Value="{StaticResource BgBrush}"/>
                            <Setter Property="BorderBrush"               Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness"           Value="0,0,0,1"/>
                            <Setter Property="FontWeight"                Value="SemiBold"/>
                            <Setter Property="Padding"                   Value="10,0,10,0"/>
                            <Setter Property="VerticalContentAlignment"  Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Cursor"                    Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- Rows -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground"              Value="White"/>
                            <Setter Property="FontSize"                Value="13"/>
                            <Setter Property="Height"                  Value="34"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Background"              Value="{StaticResource PanelBrush}"/>
                            <Setter Property="BorderBrush"             Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness"         Value="0,0,0,1"/>
                            <Style.Triggers>

                                <!-- OUT OF STOCK -->
                                <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                    <Setter Property="Background" Value="#FF3B30"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>

                                <!-- LOW STOCK -->
                                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                    <Setter Property="Background" Value="#FFC107"/>
                                    <Setter Property="Foreground" Value="DarkOrange"/>
                                </DataTrigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>

                        <!-- Cells -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"                   Value="0"/>
                            <Setter Property="VerticalContentAlignment"  Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="BorderThickness"           Value="0"/>
                            <Setter Property="Background"                Value="Transparent"/>
                        </Style>

                        <!-- Cell text style -->
                        <Style x:Key="QBCellText" TargetType="TextBlock">
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Setter Property="TextAlignment"       Value="Left"/>
                            <Setter Property="TextTrimming"        Value="CharacterEllipsis"/>
                            <Setter Property="Margin"              Value="10,0,10,0"/>
                        </Style>

                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Item #"
                                            Binding="{Binding Id}"
                                            SortMemberPath="Id"
                                            Width="70"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Item Name"
                                            Binding="{Binding Name}"
                                            SortMemberPath="Name"
                                            Width="*"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Department"
                                            Binding="{Binding Department}"
                                            SortMemberPath="Department"
                                            Width="150"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Item Description"
                                            Binding="{Binding Description}"
                                            SortMemberPath="Description"
                                            Width="180"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding Size}"
                                            SortMemberPath="Size"
                                            Width="90"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Regular Price"
                                            Binding="{Binding Price, StringFormat=R {0:0.00}}"
                                            SortMemberPath="Price"
                                            Width="120"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="On-hand Qty"
                                            Binding="{Binding StockQty}"
                                            SortMemberPath="StockQty"
                                            Width="100"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="SKU"
                                            Binding="{Binding SKU}"
                                            SortMemberPath="SKU"
                                            Width="140"
                                            ElementStyle="{StaticResource QBCellText}"/>

                        <DataGridTextColumn Header="Alternate Lookup"
                                            Binding="{Binding ALU}"
                                            SortMemberPath="ALU"
                                            Width="140"
                                            ElementStyle="{StaticResource QBCellText}"/>

                    </DataGrid.Columns>

                </DataGrid>

                <TextBlock Grid.Row="1"
                           x:Name="MsgText"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="2,10,2,0"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>
