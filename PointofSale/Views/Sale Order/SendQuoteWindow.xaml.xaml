<Window x:Class="PointofSale.Views.SendQuoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Quotation"
        Width="480" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111111">

    <StackPanel Margin="24,20,24,20">

        <TextBlock Text="📧  Send Quotation"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="QuoteRefTxt"
                   Foreground="#888888" FontSize="12"
                   Margin="0,0,0,20"/>

        <!-- Email section -->
        <Border Background="#1A1A1A" BorderBrush="#2E2E2E"
                BorderThickness="1" CornerRadius="6" Padding="14,12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="📧  Send via Email"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="To:" Foreground="#AAAAAA"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="EmailBox"
                             Grid.Column="1" Height="28"
                             Background="#0E0E0E" Foreground="White"
                             BorderBrush="#333333" BorderThickness="1"
                             Padding="6,2" FontSize="12"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Subject:" Foreground="#AAAAAA"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="SubjectBox"
                             Grid.Column="1" Height="28"
                             Background="#0E0E0E" Foreground="White"
                             BorderBrush="#333333" BorderThickness="1"
                             Padding="6,2" FontSize="12"/>
                </Grid>
                <Button Content="Send Email"
                        Height="30" Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Background="#2F66C8" Foreground="White"
                        BorderBrush="#1F4E9A" BorderThickness="1"
                        FontWeight="SemiBold" Cursor="Hand"
                        Click="SendEmail_Click"/>
            </StackPanel>
        </Border>

        <!-- WhatsApp section -->
        <Border Background="#1A1A1A" BorderBrush="#2E2E2E"
                BorderThickness="1" CornerRadius="6" Padding="14,12"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="💬  Send via WhatsApp"
                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Phone:" Foreground="#AAAAAA"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBox x:Name="WhatsAppBox"
                             Grid.Column="1" Height="28"
                             Background="#0E0E0E" Foreground="White"
                             BorderBrush="#333333" BorderThickness="1"
                             Padding="6,2" FontSize="12"/>
                </Grid>
                <Button Content="Open WhatsApp"
                        Height="30" Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        Background="#25D366" Foreground="White"
                        BorderBrush="#1DA851" BorderThickness="1"
                        FontWeight="SemiBold" Cursor="Hand"
                        Click="SendWhatsApp_Click"/>
            </StackPanel>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusTxt"
                   Foreground="#4CAF50" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,10"
                   TextWrapping="Wrap"/>

        <Button Content="Close"
                HorizontalAlignment="Right"
                Width="90" Height="30"
                Background="#2A2A2A" Foreground="White"
                BorderBrush="#3A3A3A" BorderThickness="1"
                Cursor="Hand" Click="CloseBtn_Click"/>
    </StackPanel>
</Window>
