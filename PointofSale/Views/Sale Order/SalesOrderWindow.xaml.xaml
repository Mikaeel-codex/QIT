<Window x:Class="PointofSale.Views.SalesOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Order / Quotation"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Width="1200" Height="503">

    <Window.Resources>

        <!-- ── Local colour aliases ──────────────────────────────────────── -->
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB"/>
        <SolidColorBrush x:Key="GreenOk"    Color="#16A34A"/>
        <SolidColorBrush x:Key="RedDanger"  Color="#DC2626"/>
        <SolidColorBrush x:Key="InputBg"    Color="#1E2130"/>
        <SolidColorBrush x:Key="DarkBorder" Color="#2A2D3E"/>
        <SolidColorBrush x:Key="MutedFg"    Color="#9CA3AF"/>

        <!-- ── Dark outline button ───────────────────────────────────────── -->
        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E2130"/>
            <Setter Property="Foreground"      Value="#E0E0E0"/>
            <Setter Property="BorderBrush"     Value="#2A2D3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252840"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1D30"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueBtn" TargetType="Button" BasedOn="{StaticResource OutlineBtn}">
            <Setter Property="Background"  Value="#2563EB"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource OutlineBtn}">
            <Setter Property="Background"  Value="#16A34A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#15803D"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <Style x:Key="RedOutlineBtn" TargetType="Button" BasedOn="{StaticResource OutlineBtn}">
            <Setter Property="Foreground"  Value="#F87171"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#9CA3AF"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#1E2130"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="SelectionBrush"           Value="#2563EB"/>
            <Setter Property="BorderBrush"              Value="#2A2D3E"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="28"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid styles -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"                Value="#1E2130"/>
            <Setter Property="Foreground"                Value="White"/>
            <Setter Property="FontWeight"                Value="Bold"/>
            <Setter Property="FontSize"                  Value="12"/>
            <Setter Property="Padding"                   Value="10,0"/>
            <Setter Property="Height"                    Value="36"/>
            <Setter Property="BorderThickness"           Value="0,0,0,1"/>
            <Setter Property="BorderBrush"               Value="#2A2D3E"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252840"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0F1117"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Height"     Value="36"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#181A20"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A8A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="VerticalAlignment"        Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0" Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- ① Top nav -->
            <RowDefinition Height="Auto"/>   <!-- ② SO# / Status / Date -->
            <RowDefinition Height="Auto"/>   <!-- ③ Add Items -->
            <RowDefinition Height="*"/>      <!-- ④ DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- ⑤ Item toolbar (collapsed until row selected) -->
            <RowDefinition Height="260"/>    <!-- ⑥ Bottom panels -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             ① TOP NAV BAR
        ═════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#2563EB" Margin="0,0,10,0">
                        <TextBlock Text="SO" Foreground="White" FontSize="12"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="New Sales Order"
                                   Foreground="White" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="Create a new sales order"
                                   Foreground="#9CA3AF" FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabelTxt"
                               Foreground="#9CA3AF" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="⌂  Home"
                            Style="{StaticResource OutlineBtn}"
                            Click="HomeBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ② SO# / Status / Date row   (Switch To removed)
        ═════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <!-- Print -->
                <Button Grid.Column="0" x:Name="PrintBtn"
                        Content="🖨  Print"
                        Style="{StaticResource OutlineBtn}"
                        Margin="0,0,8,0"
                        Click="PrintBtn_Click"/>

                <!-- Email -->
                <Button Grid.Column="1" x:Name="SendBtn"
                        Content="✉  Email"
                        Style="{StaticResource OutlineBtn}"
                        Click="SendBtn_Click"/>

                <!-- SO # -->
                <TextBlock Grid.Column="3" Text="SO #"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <Border Grid.Column="4"
                        Background="#1E2130"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="8,4">
                    <TextBlock x:Name="QuoteNumberTxt"
                               Text="(new)" FontSize="12" Foreground="White"/>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Column="6" Text="Status"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="7"
                          x:Name="StatusCombo"
                          Height="30" FontSize="12"
                          Background="#1E2130" Foreground="White"
                          BorderBrush="{StaticResource BorderBrush}">
                    <ComboBoxItem Content="Open" IsSelected="True"/>
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="Closed"/>
                </ComboBox>

                <!-- Order Date -->
                <TextBlock Grid.Column="9" Text="Order Date"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <Border Grid.Column="10"
                        Background="#1E2130"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅 " FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock x:Name="OrderDateTxt" FontSize="12" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Expiry -->
                <TextBlock Grid.Column="12" Text="Expires"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <DatePicker x:Name="ExpiryDatePicker"
                            Grid.Column="13"
                            Height="28" FontSize="12"
                            Background="#1E2130" Foreground="White"
                            BorderBrush="{StaticResource BorderBrush}"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ③ ADD ITEMS ROW
        ═════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#13141C"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Add Items"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <!-- Scan box -->
                <Border Grid.Column="1" Grid.ColumnSpan="2"
                        Background="#1E2130"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ScanBox"
                                 Grid.Column="0"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" CaretBrush="White"
                                 FontSize="12" Height="32"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 KeyDown="ScanBox_KeyDown"
                                 TextChanged="ScanBox_TextChanged"
                                 Panel.ZIndex="1"/>
                        <TextBlock Grid.Column="0"
                                   Text="Scan barcode or type item name, SKU, or description..."
                                   Foreground="#4B5563" FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="10,0,0,0" Panel.ZIndex="0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ScanBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Grid.Column="1"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="ScanDropdown_Click">
                            <TextBlock Text="🔍" FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Product results popup -->
                <Popup x:Name="ProductPopup"
                       Grid.Column="1"
                       PlacementTarget="{Binding ElementName=ScanBox}"
                       Placement="Bottom" StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#1B1B1B"
                            BorderBrush="#2A2D3E"
                            BorderThickness="1" CornerRadius="8"
                            Width="800" MaxHeight="360">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.45"
                                              BlurRadius="20" ShadowDepth="6"
                                              Direction="270"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Background="#1E2130" Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Item Name" Foreground="White" FontSize="11" FontWeight="Bold" Padding="12,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="SKU"       Foreground="White" FontSize="11" FontWeight="Bold" Padding="8,0"    VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="ALU"       Foreground="White" FontSize="11" FontWeight="Bold" Padding="8,0"    VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Attribute" Foreground="White" FontSize="11" FontWeight="Bold" Padding="8,0"    VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Size"      Foreground="White" FontSize="11" FontWeight="Bold" Padding="8,0"    VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Price"     Foreground="White" FontSize="11" FontWeight="Bold" Padding="8,0,12,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <ListBox x:Name="ProductList"
                                     Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="ProductList_MouseDoubleClick"
                                     KeyDown="ProductList_KeyDown">
                                <ListBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"    Color="#1E2130"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                </ListBox.Resources>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"    Value="0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor"     Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E2130"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1D3461"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2A2D3E" BorderThickness="0,0,0,1" MinHeight="38">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="260"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"       Margin="12,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="White"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SKU}"        Padding="8,0" VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF"/>
                                                <TextBlock Grid.Column="2" Text="{Binding ALU}"        Padding="8,0" VerticalAlignment="Center" FontSize="11" Foreground="#9CA3AF"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Department}" Padding="8,0" VerticalAlignment="Center" FontSize="11" Foreground="White"/>
                                                <TextBlock Grid.Column="4" Text="{Binding Size}"       Padding="8,0" VerticalAlignment="Center" FontSize="11" Foreground="White"/>
                                                <TextBlock Grid.Column="5" Text="{Binding Price, StringFormat='R {0:N2}'}" Padding="8,0,12,0" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#2563EB"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>

                <!-- Promo Code -->
                <TextBlock Grid.Column="4" Text="Promo Code"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <Border Grid.Column="5"
                        Background="#1E2130"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6">
                    <TextBox x:Name="PromoCodeBox"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" CaretBrush="White"
                             FontSize="12" Height="30"
                             VerticalContentAlignment="Center" Padding="8,0"/>
                </Border>
                <Button Grid.Column="6" Content="Apply"
                        Style="{StaticResource BlueBtn}"
                        Height="30" Margin="6,0,0,0"/>

                <!-- Associate -->
                <TextBlock Grid.Column="8" Text="Associate"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="9" Grid.ColumnSpan="2"
                          x:Name="AssociateBox"
                          Background="#1E2130" Foreground="White"
                          BorderBrush="{StaticResource BorderBrush}"
                          Height="30" FontSize="12" IsEditable="True"/>

                <!-- Cashier -->
                <TextBlock Grid.Column="12" Text="Cashier"
                           Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                <Border Grid.Column="13"
                        Background="#1E2130"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="8,4">
                    <TextBlock x:Name="CashierNameTxt"
                               FontSize="12" Foreground="#9CA3AF"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ④ DATA GRID
        ═════════════════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="3"
                  x:Name="QuoteGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  BorderThickness="0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AlternationCount="2"
                  Background="#0F1117"
                  RowBackground="#0F1117"
                  AlternatingRowBackground="#181A20"
                  RowHeight="36"
                  FontSize="12"
                  EnableRowVirtualization="True"
                  SelectionChanged="QuoteGrid_SelectionChanged">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="Transparent"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="Transparent"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
            </DataGrid.Resources>

            <DataGrid.Columns>

                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="50" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground"        Value="#9CA3AF"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Item Name" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight"        Value="SemiBold"/>
                            <Setter Property="Foreground"        Value="White"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Attribute" Binding="{Binding Attribute}" Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Size"      Binding="{Binding Size}"      Width="80"  IsReadOnly="True"/>

                <DataGridTemplateColumn Header="Ordered" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Qty}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#1E2130" Foreground="White"
                                     CaretBrush="White" BorderBrush="#2A2D3E"
                                     Padding="4,2" VerticalContentAlignment="Center" Height="28"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="On-hand" Binding="{Binding StockQty}" Width="80" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Foreground"          Value="#9CA3AF"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Padding"             Value="0,0,6,0"/>
                            <Setter Property="Foreground"          Value="White"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Ext Price" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Padding"             Value="0,0,6,0"/>
                            <Setter Property="FontWeight"          Value="SemiBold"/>
                            <Setter Property="Foreground"          Value="{StaticResource GoldBrush}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Disc %" Binding="{Binding DiscountPct, StringFormat=N1}" Width="70" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                            <Setter Property="Foreground"          Value="#9CA3AF"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Tax" Binding="{Binding TaxCode}" Width="80" IsReadOnly="True"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ════════════════════════════════════════════════════════════════
             ⑤ EDIT ITEM / QTY± / REMOVE ROW  — hidden until a row is selected
        ═════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                x:Name="ItemToolbar"
                Visibility="Collapsed"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource OutlineBtn}"
                        Click="EditLine_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏ " FontSize="11"/>
                        <TextBlock Text="Edit Item" FontSize="12"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Qty +"
                            Style="{StaticResource OutlineBtn}"
                            Width="72" Margin="0,0,6,0"
                            Click="QtyPlus_Click"/>
                    <Button Content="Qty -"
                            Style="{StaticResource OutlineBtn}"
                            Width="72"
                            Click="QtyMinus_Click"/>
                </StackPanel>

                <Button Grid.Column="6"
                        Style="{StaticResource RedOutlineBtn}"
                        Click="RemoveLine_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑 " FontSize="11"/>
                        <TextBlock Text="Remove Item" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Border Grid.Column="7"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Margin="8,0,0,0" Background="#1E2130">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="4">
                        <TextBlock Text="📷" FontSize="16"
                                   HorizontalAlignment="Center" Foreground="#9CA3AF"/>
                        <TextBlock Text="No Picture" FontSize="8"
                                   Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Assigned" FontSize="8"
                                   Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════════
             ⑥ BOTTOM PANELS: Customer Info | Shipping | Instructions | Totals
        ═════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ── Customer Info ─────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,1,0"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="👤" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Customer Info"
                                   FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <!-- Search row -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#1E2130"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CustomerNameBox"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" CaretBrush="White"
                                         FontSize="12" Height="30"
                                         VerticalContentAlignment="Center" Padding="8,0"
                                         KeyDown="CustomerNameBox_KeyDown"/>
                                <TextBlock Grid.Column="0"
                                           Text="Search customer name..."
                                           Foreground="#4B5563" FontSize="11"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center" Padding="8,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=CustomerNameBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Click="CustomerDropdown_Click">
                                    <TextBlock Text="▾" FontSize="11" Foreground="#9CA3AF"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Button Grid.Column="2"
                                Content="Find"
                                Style="{StaticResource BlueBtn}"
                                Width="52" Height="30"
                                Click="FindCustomer_Click"/>
                    </Grid>

                    <!-- Customer search popup -->
                    <Popup x:Name="CustomerPopup"
                           PlacementTarget="{Binding ElementName=CustomerNameBox}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="#1B1B1B"
                                BorderBrush="#2A2D3E"
                                BorderThickness="1" CornerRadius="8"
                                MinWidth="300" MaxHeight="260">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.45"
                                                  BlurRadius="16" ShadowDepth="4"
                                                  Direction="270"/>
                            </Border.Effect>
                            <ListBox x:Name="CustomerList"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="CustomerList_MouseDoubleClick"
                                     KeyDown="CustomerList_KeyDown">
                                <ListBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"    Color="#1E2130"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                </ListBox.Resources>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"    Value="0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor"     Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E2130"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1D3461"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#2A2D3E" BorderThickness="0,0,0,1"
                                                Padding="12,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}"
                                                           Foreground="White" FontSize="12"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Phone}"
                                                           Foreground="#9CA3AF" FontSize="11"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>

                    <!-- Selected customer detail card -->
                    <Border Grid.Row="2"
                            x:Name="CustomerDetailPanel"
                            Visibility="Collapsed"
                            Background="#1A1C28"
                            BorderBrush="#2A2D3E"
                            BorderThickness="1" CornerRadius="8"
                            Margin="0,8,0,0"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Address"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="CustAddressTxt"
                                       Foreground="White" FontSize="11"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Phone"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       x:Name="CustPhoneTxt"
                                       Foreground="White" FontSize="11"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Balance"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       x:Name="CustBalanceTxt"
                                       Foreground="#F87171" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Credit"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1"
                                       x:Name="CustCreditTxt"
                                       Foreground="#4ADE80" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- ── Shipping Info ──────────────────────────────────────────── -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,1,0"
                    Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🚚" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Shipping Info"
                                   FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                    <Button Content="Enter Shipping Info"
                            Style="{StaticResource BlueBtn}"
                            Height="36" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- ── Instructions ──────────────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,1,0"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📋" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Instructions"
                                   FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#1E2130"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <TextBox x:Name="NotesBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="White" CaretBrush="White"
                                 FontSize="12" AcceptsReturn="True"
                                 TextWrapping="Wrap" Padding="8,6"
                                 MinHeight="90"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="0 / 1000"
                                   Foreground="#9CA3AF" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="💾 Save Draft"
                                    Style="{StaticResource OutlineBtn}"
                                    Margin="0,0,6,0" Height="28"
                                    Click="SaveDraft_Click"/>
                            <Button x:Name="SubmitBtn"
                                    Content="📤 Submit"
                                    Style="{StaticResource BlueBtn}"
                                    Margin="0,0,6,0" Height="28"
                                    Click="SubmitApproval_Click"/>
                            <Button x:Name="ApproveBtn"
                                    Content="✅ Approve"
                                    Style="{StaticResource GreenBtn}"
                                    Margin="0,0,6,0" Height="28"
                                    Visibility="Collapsed"
                                    Click="ApproveBtn_Click"/>
                            <Button x:Name="RejectBtn"
                                    Content="❌ Reject"
                                    Style="{StaticResource RedOutlineBtn}"
                                    Margin="0,0,6,0" Height="28"
                                    Visibility="Collapsed"
                                    Click="RejectBtn_Click"/>
                            <Button x:Name="ConvertBtn"
                                    Content="🔄 Convert"
                                    Style="{StaticResource GreenBtn}"
                                    Margin="0,0,6,0" Height="28"
                                    Visibility="Collapsed"
                                    Click="ConvertBtn_Click"/>
                            <Button x:Name="CancelQuoteBtn"
                                    Content="Cancel"
                                    Style="{StaticResource RedOutlineBtn}"
                                    Height="28"
                                    Click="CancelQuote_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Totals ─────────────────────────────────────────────────── -->
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Price Level" Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,4"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  Width="150" Height="24" FontSize="11" Margin="0,0,0,4">
                            <ComboBoxItem Content="Regular Price" IsSelected="True"/>
                            <ComboBoxItem Content="Sale"/>
                            <ComboBoxItem Content="Wholesale"/>
                            <ComboBoxItem Content="Employee"/>
                            <ComboBoxItem Content="Custom Price"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Sub Total"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Right" Margin="0,4,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SubtotalTxt"
                                   HorizontalAlignment="Right" FontSize="11"
                                   FontWeight="SemiBold" Foreground="White" Margin="0,4,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Disc %"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <Border Grid.Row="2" Grid.Column="1"
                                Background="#1E2130"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Width="110" Height="24">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     Text="0.00" FontSize="11"
                                     Foreground="White" CaretBrush="White"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center" Padding="4,0"/>
                        </Border>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Discount"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Right" Margin="0,4,0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DiscountTxt"
                                   Text="R 0.00" HorizontalAlignment="Right"
                                   FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,4"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Shipping"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Text="R 0.00" HorizontalAlignment="Right"
                                   FontSize="11" Foreground="#9CA3AF" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Tax"
                                   Foreground="#9CA3AF" FontSize="11"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TaxTxt"
                                   HorizontalAlignment="Right" FontSize="11"
                                   Foreground="#9CA3AF"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#1E3A8A" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total"
                                   Foreground="White" FontSize="14"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TotalTxt"
                                   Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#162F6A" Padding="14,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Balance Due"
                                   Foreground="White" FontSize="12"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="BalanceDueTxt"
                                   Foreground="White" FontSize="16"
                                   FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>

        </Grid>

        <!-- Required field note -->
        <TextBlock Grid.Row="5"
                   Text="* Required Field"
                   Foreground="#DC2626" FontSize="10"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="16,0,0,4" Panel.ZIndex="10"/>

    </Grid>
</Window>
