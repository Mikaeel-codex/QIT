<Window x:Class="PointofSale.Views.HeldReceiptsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Held Receipts"
        Width="1300" Height="700"
        MinWidth="1000" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#111111"
        Foreground="White">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#1A1A2E"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush"     Value="#2B2B40"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="12"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#111111"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A6E"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222244"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2F66C8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#1F4E9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background"  Value="#8B0000"/>
            <Setter Property="BorderBrush" Value="#600000"/>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background"  Value="#2E7D32"/>
            <Setter Property="BorderBrush" Value="#1B5E20"/>
        </Style>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="0"
                Background="#0D0D1A"
                BorderBrush="#2B2B40"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Held Receipts"
                               FontSize="16" FontWeight="Bold"
                               Foreground="White" Margin="0,0,24,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Period:" Style="{StaticResource DetailLabel}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PeriodBox"
                              Width="130" Height="28"
                              Background="#0E0E0E" Foreground="White"
                              BorderBrush="#333"
                              SelectionChanged="Period_Changed">
                        <ComboBoxItem Content="Last 30 Days" IsSelected="True"/>
                        <ComboBoxItem Content="Last 7 Days"/>
                        <ComboBoxItem Content="Today"/>
                        <ComboBoxItem Content="All"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0E0E0E" BorderBrush="#333" BorderThickness="1"
                            CornerRadius="3" Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="#666" VerticalAlignment="Center"
                                       FontSize="11" Margin="0,0,4,0"/>
                            <TextBox x:Name="SearchBox"
                                     Width="190" Height="28"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0"
                                     Padding="0" VerticalContentAlignment="Center"
                                     FontSize="12" CaretBrush="White"
                                     TextChanged="Search_Changed"
                                     ToolTip="Search by cashier, customer or items"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Unhold" Margin="12,0,0,0"
                            Style="{StaticResource GreenBtn}"
                            Click="Unhold_Click"/>
                    <Button Content="Delete" Margin="6,0,0,0"
                            Style="{StaticResource DangerBtn}"
                            Click="Delete_Click"/>
                    <Button x:Name="ShowDetailsBtn"
                            Content="Show Details" Margin="6,0,0,0"
                            Style="{StaticResource ToolBtn}"
                            Click="ShowDetails_Click"/>
                    <Button Content="Close"  Margin="6,0,0,0"
                            Style="{StaticResource ToolBtn}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BODY: list LEFT + detail RIGHT ═══ -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition x:Name="DetailCol" Width="0" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Held receipts list ── -->
            <Border Grid.Column="0"
                    BorderBrush="#2B2B40" BorderThickness="0,0,1,0">
                <DataGrid x:Name="HeldGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          AlternationCount="2"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="#181818"
                          AlternatingRowBackground="#111111"
                          Foreground="White"
                          FontSize="12"
                          RowHeight="40"
                          MouseDoubleClick="HeldGrid_DoubleClick"
                          SelectionChanged="HeldGrid_SelectionChanged">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date / Time"
                            Binding="{Binding HeldAt, StringFormat=MM/dd/yyyy  HH:mm}"
                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Cashier"
                            Binding="{Binding Cashier}"
                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Customer"
                            Binding="{Binding CustomerName}"
                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Items Held"
                            Binding="{Binding ItemsSummary}"
                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming"     Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip"          Value="{Binding ItemsSummary}"/>
                                    <Setter Property="Foreground"       Value="#88BBFF"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding"          Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="No. of Items"
                            Binding="{Binding ItemCount}"
                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total Qty Sold"
                            Binding="{Binding TotalQty}"
                            Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total"
                            Binding="{Binding Total, StringFormat=N2}"
                            Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment"   Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding"             Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Payment"
                            Binding="{Binding PaymentMethod}"
                            Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                    <!-- Hint row at the bottom when empty -->
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </DataGrid.Style>
                </DataGrid>
            </Border>

            <!-- ── RIGHT: Detail Page hosted in a Frame ── -->
            <Border Grid.Column="1"
                    BorderBrush="#CCCCCC" BorderThickness="1,0,0,0"
                    Background="White">
                <Frame x:Name="DetailFrame"
                       NavigationUIVisibility="Hidden"
                       Background="White"/>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2"
                Background="#0D0D1A"
                BorderBrush="#2B2B40" BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <TextBlock x:Name="StatusTxt"
                           Foreground="#888888" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Double-click a row to view receipt detail"
                           Foreground="#555566" FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
