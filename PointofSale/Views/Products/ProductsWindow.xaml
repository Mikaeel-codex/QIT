<Window x:Class="PointofSale.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory - Item List"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height"         Value="36"/>
            <Setter Property="Padding"        Value="14,0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                Background="#13141C"
                BorderBrush="#2A2D3E"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16,14"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Blue icon + Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="10"
                            Background="#2563EB" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8B8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Item List"
                                   Foreground="White"
                                   FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Add, edit, and manage stock"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search box -->
                <Border Grid.Column="1"
                        Margin="28,0"
                        Background="#1E2130"
                        BorderBrush="#2A2D3E"
                        BorderThickness="1"
                        CornerRadius="9"
                        Height="38"
                        VerticalAlignment="Center">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Magnifier glyph -->
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#6B7280"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <!-- Input -->
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 SelectionBrush="#2563EB"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 FontSize="13"
                                 Padding="0"
                                 Height="Auto"/>

                        <!-- Placeholder -->
                        <TextBlock Grid.Column="1"
                                   Text="Search inventory..."
                                   Foreground="#4B5563"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <Button Style="{StaticResource ActionButton}"
                            Background="#374151"
                            Margin="0,0,8,0"
                            Click="RefreshBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="AddBtn"
                            Style="{StaticResource ActionButton}"
                            Background="#16A34A"
                            Margin="0,0,8,0"
                            Click="AddBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Add" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="EditBtn"
                            Style="{StaticResource ActionButton}"
                            Background="#CA8A04"
                            Margin="0,0,8,0"
                            Click="EditBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Edit" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DeleteBtn"
                            Style="{StaticResource ActionButton}"
                            Background="#DC2626"
                            Click="DeleteBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ DATA GRID ══ -->
        <Border Grid.Row="1"
                Background="#0F1117"
                BorderBrush="#2A2D3E"
                BorderThickness="1"
                CornerRadius="14"
                ClipToBounds="True">

            <DataGrid x:Name="ProductsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      Background="#0F1117"
                      Foreground="White"
                      RowBackground="#0F1117"
                      AlternatingRowBackground="#181A20"
                      BorderThickness="0"
                      SelectionMode="Single"
                      ColumnHeaderHeight="38"
                      RowHeight="36"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      HorizontalScrollBarVisibility="Hidden"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True"
                      ItemsSource="{Binding View}"
                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                      MouseDoubleClick="ProductsGrid_MouseDoubleClick">

                <DataGrid.Resources>

                    <!-- Neutralise the system selection brush so our row Background shows through -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="White"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>

                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Foreground"                 Value="White"/>
                        <Setter Property="Background"                 Value="#1E2130"/>
                        <Setter Property="BorderBrush"                Value="#2A2D3E"/>
                        <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                        <Setter Property="FontWeight"                 Value="Bold"/>
                        <Setter Property="FontSize"                   Value="13"/>
                        <Setter Property="Padding"                    Value="12,0"/>
                        <Setter Property="Height"                     Value="38"/>
                        <Setter Property="VerticalContentAlignment"   Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Cursor"                     Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252840"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1D30"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground"               Value="White"/>
                        <Setter Property="FontSize"                 Value="13"/>
                        <Setter Property="Height"                   Value="36"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness"          Value="0,0,0,1"/>
                        <Setter Property="BorderBrush"              Value="#1A1D2E"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                <Setter Property="Foreground" Value="#F87171"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                <Setter Property="Foreground" Value="#FBBF24"/>
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E3A8A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1D2E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"                   Value="0"/>
                        <Setter Property="VerticalContentAlignment"  Value="Center"/>
                        <Setter Property="BorderThickness"           Value="0"/>
                        <Setter Property="Background"                Value="Transparent"/>
                        <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="BorderBrush"  Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>

                    <Style x:Key="CellText" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextTrimming"      Value="CharacterEllipsis"/>
                        <Setter Property="Margin"            Value="12,0"/>
                    </Style>

                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item #"
                                        Binding="{Binding Id}"
                                        Width="70"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Item Name"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Department"
                                        Binding="{Binding Department}"
                                        Width="140"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="180"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Size"
                                        Binding="{Binding Size}"
                                        Width="80"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Regular Price"
                                        Binding="{Binding Price, StringFormat=R {0:0.00}}"
                                        Width="120"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="On-hand Qty"
                                        Binding="{Binding StockQty}"
                                        Width="100"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="SKU"
                                        Binding="{Binding SKU}"
                                        Width="140"
                                        ElementStyle="{StaticResource CellText}"/>
                    <DataGridTextColumn Header="Alternate Lookup"
                                        Binding="{Binding ALU}"
                                        Width="140"
                                        ElementStyle="{StaticResource CellText}"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>

        <!-- ══ STATUS BAR ══ -->
        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="14,7"
                Background="#13141C"
                BorderBrush="#2A2D3E"
                BorderThickness="1"
                CornerRadius="8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#9CA3AF"
                       FontSize="12"/>
        </Border>

    </Grid>
</Window>
