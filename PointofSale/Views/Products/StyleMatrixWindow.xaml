<Window x:Class="PointofSale.Views.StyleMatrixWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Style"
        Width="900" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        Foreground="White">

    <Window.Resources>

        <Style x:Key="HeaderCell" TargetType="Border">
            <Setter Property="Background"      Value="#2D2D2D"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="DataCell" TargetType="Border">
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="BorderBrush"     Value="#383838"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="TotalCell" TargetType="Border">
            <Setter Property="Background"      Value="#2A2A2A"/>
            <Setter Property="BorderBrush"     Value="#444444"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="CellTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontWeight"               Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment"            Value="Center"/>
            <Setter Property="Padding"                  Value="4,0"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="SelectionBrush"           Value="#F4C542"/>
        </Style>

        <Style x:Key="SizeCellTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontWeight"               Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment"            Value="Center"/>
            <Setter Property="Padding"                  Value="4,0"/>
            <Setter Property="CaretBrush"               Value="White"/>
            <Setter Property="SelectionBrush"           Value="#F4C542"/>
        </Style>

    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- top info bar -->
            <RowDefinition Height="*"/>
            <!-- matrix -->
            <RowDefinition Height="Auto"/>
            <!-- status + buttons -->
        </Grid.RowDefinitions>

        <!-- ── TOP BAR ── -->
        <Border Grid.Row="0"
                Background="#2A2A2A"
                BorderBrush="#3A3A3A"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="16"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Item Name"
                           Foreground="#CCCCCC" FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="ItemNameBox"
                         Grid.Column="1"
                         Height="28"
                         Background="#111111"
                         Foreground="White"
                         BorderBrush="#444444"
                         BorderThickness="1"
                         Padding="6,2"
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         CaretBrush="White"/>

                <TextBlock Grid.Column="3" Text="Department"
                           Foreground="#CCCCCC" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="DepartmentBox"
                          Grid.Column="4"
                          Height="28"
                          IsEditable="True"
                          Background="#111111"
                          Foreground="White"
                          BorderBrush="#444444"
                          BorderThickness="1"
                          FontSize="12"/>
                <TextBlock Grid.Column="5" Text="*"
                           Foreground="Red" FontSize="14"
                           VerticalAlignment="Center" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- ── MATRIX ── -->
        <Border Grid.Row="1"
                Background="#1E1E1E"
                Margin="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <!-- The entire matrix is built in code-behind and placed here -->
                <Grid x:Name="MatrixContainer"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="8,8,8,8"/>
            </ScrollViewer>
        </Border>

        <!-- ── FOOTER ── -->
        <Border Grid.Row="2"
                Background="#2A2A2A"
                BorderBrush="#3A3A3A"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusTxt"
                           Grid.Column="0"
                           Foreground="#FF6B6B"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <Button Grid.Column="1"
                        Content="Save"
                        Width="110" Height="32"
                        Background="#3A7D44"
                        BorderBrush="#2D6035"
                        BorderThickness="1"
                        Foreground="White"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Cursor="Hand"
                        Click="SaveBtn_Click"/>

                <Button Grid.Column="3"
                        Content="Cancel"
                        Width="90" Height="32"
                        Background="#3A3A3A"
                        BorderBrush="#4A4A4A"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="13"
                        Cursor="Hand"
                        Click="CancelBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
